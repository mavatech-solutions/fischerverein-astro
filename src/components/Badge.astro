---
interface Props {
  text: string;
  color?: 'primary' | 'dark' | 'gray';
}

const { text, color = 'primary' } = Astro.props;

const colors = {
  primary: 'bg-[var(--color-primary)] text-white',
  dark: 'bg-[var(--color-dark)] text-white',
  gray: 'bg-gray-200 text-[var(--color-dark)]',
};
---

<span class={`inline-block px-3 py-1 rounded-full text-sm font-medium mb-4 ${colors[color]}`}>
  {text}
</span>
