---
import "../styles/global.css";
import MuiButton from "../components/MuiButton.jsx";
import logoSrc from "../assets/images/logo.svg";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Fischerverein – Webseite" } = Astro.props;
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Fischerverein</title>

    <script is:inline>
      try {
        const isAuthed = document.cookie.includes("sb-auth=1");
        const isAdmin = document.cookie.includes("sb-role=admin");
        document.documentElement.dataset.authed = isAuthed ? "true" : "false";
        document.documentElement.dataset.admin = isAdmin ? "true" : "false";
      } catch (e) {
        document.documentElement.dataset.authed = "false";
        document.documentElement.dataset.admin = "false";
      }
    </script>
  </head>
  <body class="min-h-screen bg-gray-50 flex flex-col">
    <header class="bg-white text-[var(--color-dark)] shadow-md">
      <nav
        class="container mx-auto px-4 py-4 flex items-center justify-between"
      >
        <!-- Logo -->
        <a href="/" class="flex items-center">
          <img src={logoSrc.src} alt="Fischerverein Logo" class=" w-auto max-w-[170px]" />
        </a>

        <!-- Desktop Links -->
        <ul class="hidden lg:flex items-center gap-6 text-base font-medium">
          <li>
            <a href="/" class="hover:text-[var(--color-secondary)]"
              >Startseite</a
            >
          </li>
          <li>
            <a href="/verein" class="hover:text-[var(--color-secondary)]"
              >Über uns</a
            >
          </li>
          <li>
            <a href="/galerie" class="hover:text-[var(--color-secondary)]"
              >Galerie</a
            >
          </li>
          <li>
            <a href="/kontakt" class="hover:text-[var(--color-secondary)]"
              >Kontakt</a
            >
          </li>
          <li class="nav-member-only">
            <a href="/mitglieder/termine" class="hover:text-[var(--color-secondary)]"
              >Termine</a
            >
          </li>
          <li class="nav-member-only">
            <a href="/mitglieder/aktuelles" class="hover:text-[var(--color-secondary)]"
              >Aktuelles</a
            >
          </li>
          <li class="nav-member-only">
            <a href="/mitglieder/faenge" class="hover:text-[var(--color-secondary)]"
              >Fangbuch</a
            >
          </li>
        </ul>

        <!-- Login Button (ausgeloggt) -->
        <div id="auth-wrapper">
          <a
            id="login-btn"
            href="/mitglieder/login"
            class="hidden lg:inline-block"
          >
            <MuiButton client:only="react" text="Login" size="medium" />
          </a>

          <!-- Avatar (eingeloggt) -->
          <div id="avatar-menu" class="hidden relative">
            <button
              id="avatar-btn"
              class="flex items-center gap-1 hover:opacity-80 transition"
            >
              <span
                id="avatar-circle"
                class="w-10 h-10 rounded-full bg-[var(--color-primary)] text-white font-bold flex items-center justify-center overflow-hidden bg-cover bg-center"
              >
                <span id="avatar-initial">?</span>
              </span>
              <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <script is:inline>
              try {
                const cached = localStorage.getItem('sb-avatar-cache');
                if (cached) {
                  const { uid, avatar_url, full_name } = JSON.parse(cached);
                  const sk = Object.keys(localStorage).find(k => k.includes('auth-token'));
                  const st = sk ? JSON.parse(localStorage.getItem(sk) || '{}') : {};
                  if (st?.user?.id === uid) {
                    const el = document.getElementById('avatar-circle');
                    const init = document.getElementById('avatar-initial');
                    if (avatar_url && el) { el.style.backgroundImage = `url(${avatar_url})`; if(init) init.style.display='none'; }
                    else if (full_name && init) { init.textContent = full_name.charAt(0).toUpperCase(); }
                  }
                }
              } catch(e) {}
            </script>
            <div
              id="avatar-dropdown"
              class="hidden absolute right-0 mt-2 w-48 bg-white shadow-lg rounded-xl py-2 z-50"
            >
              <a
                href="/mitglieder/dashboard"
                class="block px-4 py-2 text-sm hover:bg-gray-100">Dashboard</a
              >
              <a
                id="admin-link"
                href="/mitglieder/admin"
                class="block px-4 py-2 text-sm hover:bg-gray-100"
                style="display:none">Admin</a
              >
              <a
                href="/mitglieder/profil"
                class="block px-4 py-2 text-sm hover:bg-gray-100">Profil</a
              >
              <hr class="my-1" />
              <button
                id="logout-btn"
                class="w-full text-left px-4 py-2 text-sm text-red-500 hover:bg-gray-100"
              >
                Abmelden
              </button>
            </div>
          </div>
        </div>
        <!-- Hamburger Button (nur Mobile) -->
        <button id="open-menu" class="lg:hidden">
          <svg
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </nav>
    </header>

    <script is:inline>
      function setHeroVh() {
        document.documentElement.style.setProperty('--hero-vh', window.innerHeight + 'px');
      }
      setHeroVh();
      window.addEventListener('resize', setHeroVh);

      const header = document.querySelector('header');
      if (header) {
        const ro = new ResizeObserver(() => {
          const h = header.offsetHeight;
          if (h > 0) document.documentElement.style.setProperty('--header-height', h + 'px');
        });
        ro.observe(header);
      }
    </script>

    <!-- Offcanvas Overlay -->
    <div id="overlay" class="fixed inset-0 bg-black/50 z-40 hidden"></div>

    <!-- Offcanvas Menu -->
    <div
      id="offcanvas"
      class="fixed top-0 right-0 h-full w-72 bg-[var(--color-primary)] text-white z-50 transform translate-x-full transition-transform duration-300 shadow-xl"
    >
      <div
        class="flex items-center justify-between p-4 border-b border-[var(--color-secondary)]"
      >
        <span class="font-bold text-lg">Menü</span>
        <button id="close-menu">
          <svg
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      <ul class="flex flex-col p-4 gap-4 font-medium">
        <li>
          <a href="/" class="block text-lg hover:text-[var(--color-secondary)]"
            >Startseite</a
          >
        </li>
        <li>
          <a href="/verein" class="block text-lg hover:text-[var(--color-secondary)]"
            >Über uns</a
          >
        </li>
        <li>
          <a href="/galerie" class="block text-lg hover:text-[var(--color-secondary)]"
            >Galerie</a
          >
        </li>
        <li>
          <a href="/kontakt" class="block text-lg hover:text-[var(--color-secondary)]"
            >Kontakt</a
          >
        </li>
        <li class="nav-member-only">
          <a href="/mitglieder/termine" class="block text-lg hover:text-[var(--color-secondary)]"
            >Termine</a
          >
        </li>
        <li class="nav-member-only">
          <a href="/mitglieder/aktuelles" class="block text-lg hover:text-[var(--color-secondary)]"
            >Aktuelles</a
          >
        </li>
        <li class="nav-member-only">
          <a href="/mitglieder/faenge" class="block text-lg hover:text-[var(--color-secondary)]"
            >Fangbuch</a
          >
        </li>
        <li id="mobile-login-li" class="mt-4">
          <a href="/mitglieder/login" class="">
            <MuiButton client:load text="Login" btnType="dark" size="small" />
          </a>
        </li>

        <!-- Mobile Avatar Section (eingeloggt) -->
        <li id="mobile-avatar-section" class="mt-4 border-t border-[var(--color-secondary)] pt-4">
          <div class="flex items-center gap-3 mb-4">
            <span
              id="mobile-avatar-circle"
              class="w-10 h-10 rounded-full bg-white/20 text-white font-bold flex items-center justify-center overflow-hidden bg-cover bg-center flex-shrink-0"
            >
              <span id="mobile-avatar-initial">?</span>
            </span>
            <span id="mobile-avatar-name" class="text-sm font-medium text-white/80"></span>
          </div>
          <ul class="space-y-3">
            <li>
              <a href="/mitglieder/dashboard" class="block text-lg hover:text-[var(--color-secondary)]">Dashboard</a>
            </li>
            <li id="mobile-admin-link" style="display:none">
              <a href="/mitglieder/admin" class="block text-lg hover:text-[var(--color-secondary)]">Admin</a>
            </li>
            <li>
              <a href="/mitglieder/profil" class="block text-lg hover:text-[var(--color-secondary)]">Profil</a>
            </li>
            <li>
              <button id="mobile-logout-btn" class="text-left text-lg text-red-500 mt-1">
                Abmelden
              </button>
            </li>
          </ul>
        </li>
      </ul>
    </div>

    <script>
      const openBtn = document.getElementById("open-menu");
      const closeBtn = document.getElementById("close-menu");
      const offcanvas = document.getElementById("offcanvas");
      const overlay = document.getElementById("overlay");

      openBtn?.addEventListener("click", () => {
        offcanvas?.classList.remove("translate-x-full");
        overlay?.classList.remove("hidden");
      });

      const close = () => {
        offcanvas?.classList.add("translate-x-full");
        overlay?.classList.add("hidden");
      };

      closeBtn?.addEventListener("click", close);
      overlay?.addEventListener("click", close);
    </script>

    <main class="flex-1" style="margin-top: var(--header-height)">
      <slot />
    </main>

    <footer class="bg-white text-white">
      <div class="container mx-auto px-6 py-12 grid grid-cols-12 gap-6">
        <div class="col-span-12 md:col-span-3 text-center md:text-left">
          <img src={logoSrc.src} alt="Fischerverein Logo" class="h-16 w-auto max-w-[170px] mx-auto md:mx-0 mb-3" />
          <p class="text-base text-[var(--color-dark)]">
            Gemeinschaft, Natur und Tradition.
          </p>
        </div>
        <div
          class="col-span-12 md:col-span-2 md:col-start-9 text-center md:text-right"
        >
          <h3 class="font-bold text-[var(--color-secondary)] mb-2">Links</h3>
          <ul class="text-base text-[var(--color-dark)] space-y-1">
            <li>
              <a href="/verein" class="hover:text-[var(--color-secondary)]"
                >Über uns</a
              >
            </li>
            <li>
              <a href="/galerie" class="hover:text-[var(--color-secondary)]"
                >Galerie</a
              >
            </li>
            <li>
              <a href="/kontakt" class="hover:text-[var(--color-secondary)]"
                >Kontakt</a
              >
            </li>
          </ul>
        </div>
        <div class="col-span-12 md:col-span-2 md:col-start-11 text-center md:text-right">
          <h3 class="font-bold text-[var(--color-secondary)] mb-2">
            Rechtliches
          </h3>
          <ul class="text-base text-[var(--color-dark)] space-y-1">
            <li>
              <a href="/impressum" class="hover:text-[var(--color-secondary)]"
                >Impressum</a
              >
            </li>
            <li>
              <a href="/datenschutz" class="hover:text-[var(--color-secondary)]"
                >Datenschutz</a
              >
            </li>
          </ul>
        </div>
      </div>
      <div class="border-t border-gray-100">
        <div class="container mx-auto px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-4">
          <span class="text-sm text-gray-400">© {new Date().getFullYear()} Fischerverein Oberstenfeld Gronau e.V. Alle Rechte vorbehalten.</span>
          <a
            href="https://mavatech-solutions.de"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col items-center sm:items-end gap-0.5"
          >
            <span class="flex items-center gap-1.5 text-sm">
              <span class="text-gray-400">powered by</span>
              <span class="font-semibold text-[var(--color-dark)] group-hover:text-[var(--color-primary)] transition-colors duration-200">
                mavatech-solutions.de
              </span>
              <svg class="w-3.5 h-3.5 text-[var(--color-primary)] opacity-0 group-hover:opacity-100 transition-opacity duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </span>
            <span class="text-xs text-gray-400 italic">Digitale Lösungen für eine digitale Welt.</span>
          </a>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById("mobile-menu-btn");
      const menu = document.getElementById("mobile-menu");
      btn?.addEventListener("click", () => menu?.classList.toggle("hidden"));
    </script>

    <script>
      import { supabase } from "../lib/supabase.js";

      const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
      const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

      // Session direkt aus localStorage lesen
      const storageKey = Object.keys(localStorage).find(k => k.includes('auth-token'));
      const stored = storageKey ? JSON.parse(localStorage.getItem(storageKey) || '{}') : {};
      const userId = stored?.user?.id;
      const jwt = stored?.access_token;

      if (userId && jwt) {
        // Gecachten Avatar sofort anwenden (kein Flash)
        const cached = localStorage.getItem('sb-avatar-cache');
        if (cached) {
          try {
            const { uid, avatar_url, full_name } = JSON.parse(cached);
            if (uid === userId) applyAvatar(avatar_url, full_name);
          } catch {}
        }

        // Frische Daten nachladen
        fetch(`${SUPABASE_URL}/rest/v1/profiles?id=eq.${userId}&select=avatar_url,full_name`, {
          headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${jwt}` }
        })
        .then(r => r.json())
        .then(data => {
          const profile = data?.[0];
          applyAvatar(profile?.avatar_url, profile?.full_name);
          localStorage.setItem('sb-avatar-cache', JSON.stringify({
            uid: userId,
            avatar_url: profile?.avatar_url,
            full_name: profile?.full_name,
          }));
        })
        .catch(() => {});
      }

      function applyAvatar(avatar_url: string, full_name: string) {
        // Desktop
        const avatarCircle = document.getElementById("avatar-circle") as HTMLElement;
        const navInitial = document.getElementById("avatar-initial");
        if (avatar_url && avatarCircle) {
          avatarCircle.style.backgroundImage = `url(${avatar_url})`;
          if (navInitial) navInitial.style.display = "none";
        } else if (full_name && navInitial) {
          navInitial.textContent = full_name.charAt(0).toUpperCase();
        }
        // Mobile
        const mobileCircle = document.getElementById("mobile-avatar-circle") as HTMLElement;
        const mobileInitial = document.getElementById("mobile-avatar-initial");
        const mobileName = document.getElementById("mobile-avatar-name");
        if (avatar_url && mobileCircle) {
          mobileCircle.style.backgroundImage = `url(${avatar_url})`;
          if (mobileInitial) mobileInitial.style.display = "none";
        } else if (full_name && mobileInitial) {
          mobileInitial.textContent = full_name.charAt(0).toUpperCase();
        }
        if (full_name && mobileName) mobileName.textContent = full_name;
      }

      // Dropdown toggle
      document.getElementById("avatar-btn")?.addEventListener("click", () => {
        document.getElementById("avatar-dropdown")?.classList.toggle("hidden");
      });

      const logoutHandler = () => {
        document.cookie = "sb-auth=; path=/; SameSite=Strict; max-age=0";
        document.cookie = "sb-role=; path=/; SameSite=Strict; max-age=0";
        for (const key of Object.keys(localStorage)) {
          if (key.startsWith("sb-")) localStorage.removeItem(key);
        }
        supabase.auth.signOut().catch(() => {});
        window.location.href = "/";
      };

      document.getElementById("logout-btn")?.addEventListener("click", logoutHandler);
      document.getElementById("mobile-logout-btn")?.addEventListener("click", logoutHandler);
    </script>
  </body>
</html>
