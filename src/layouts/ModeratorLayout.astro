---
import Layout from './Layout.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<Layout title={title}>
  <div id="page-content" style="display:none">
    <slot />
  </div>
</Layout>

<script is:inline>
  const role = document.cookie.match(/sb-role=([^;]+)/)?.[1];
  if (!document.cookie.includes('sb-auth=1') || !['admin', 'moderator'].includes(role)) {
    window.location.replace('/mitglieder/dashboard');
  } else {
    document.getElementById('page-content').style.display = 'block';
  }
</script>
