---
import Layout from "../layouts/Layout.astro";
import Badge from "../components/Badge.astro";
import CountUp from "../components/CountUp.jsx";
import MuiButton from "../components/MuiButton.jsx";
import BecomeMember from "../components/BecomeMember.astro";
import { Image } from "astro:assets";
import see1Img from "../assets/images/see1.jpeg";
import see2Img from "../assets/images/see2.jpeg";

const GRUENDUNGSDATUM = new Date(1987, 1, 16);
const heute = new Date();
const jahreTradit =
  heute.getMonth() > GRUENDUNGSDATUM.getMonth() ||
  (heute.getMonth() === GRUENDUNGSDATUM.getMonth() &&
    heute.getDate() >= GRUENDUNGSDATUM.getDate())
    ? heute.getFullYear() - GRUENDUNGSDATUM.getFullYear()
    : heute.getFullYear() - GRUENDUNGSDATUM.getFullYear() - 1;
---

<Layout title="Startseite">
  <div
    class="heading-hero flex justify-center items-center relative overflow-hidden"
    style="margin-top: calc(-1 * var(--header-height))"
  >
    <!-- Background image -->
    <img
      src={see1Img.src}
      alt=""
      class="absolute inset-0 w-full h-full object-cover object-center"
      aria-hidden="true"
    />
    <!-- Dark gradient overlay -->
    <div
      class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/50 to-black/20"
    >
    </div>
    <div class="container mx-auto px-4 py-8 relative z-10">
      <div class="grid grid-cols-12 gap-6">
        <div class="col-span-12 md:col-span-7 xl:col-span-5">
          <Badge text="Willkommen bei Fischerverein" />
          <h1 class="font-bold mb-4 text-white">
            Gemeinsam am Wasser, gemeinsam erleben.
          </h1>
          <p class="text-lg text-white">
            Seit über {jahreTradit} Jahren verbindet uns die Leidenschaft fürs Angeln.
            Werde Teil unserer Gemeinschaft und entdecke die schönsten Gewässer der
            Region.
          </p>
          <div class="mt-6 flex gap-4 flex-wrap">
            <MuiButton
              client:load
              text="Mitglied werden"
              btnType="white"
              size="large"
              href="/kontakt"
            />
            <MuiButton
              client:load
              text="Mehr erfahren"
              btnType="outline"
              size="large"
              href="/verein"
            />
          </div>
        </div>
        <div class="col-span-12 md:col-span-5 md:col-start-8"></div>
      </div>
    </div>
  </div>

  <div class="container mx-auto px-4 counter-container">
    <div class="grid grid-cols-12 gap-6">
      <div class="col-span-12 md:col-span-3">
        <div
          class="bg-[var(--color-bg-light)] shadow-md flex flex-col items-center justify-center py-8 h-[100%] counter-card"
        >
          <CountUp
            client:load
            from={0}
            to={22}
            separator=","
            direction="up"
            duration={1}
            className="text-4xl font-bold count-up-text"
            startWhen={true}
          />
          <p class="text-md">Mitglieder</p>
        </div>
      </div>

      <div class="col-span-12 md:col-span-3">
        <div
          class="bg-[var(--color-bg-light)] shadow-md flex flex-col items-center justify-center py-8 h-[100%] counter-card"
        >
          <CountUp
            client:load
            from={0}
            to={2}
            separator=","
            direction="up"
            duration={1}
            className="text-4xl font-bold count-up-text"
            startWhen={true}
          />
          <p class="text-md">Gewässer</p>
        </div>
      </div>

      <div class="col-span-12 md:col-span-3">
        <div
          class="bg-[var(--color-bg-light)] shadow-md flex flex-col items-center justify-center py-8 h-[100%] counter-card"
        >
          <CountUp
            client:load
            from={0}
            to={jahreTradit}
            separator=","
            direction="up"
            duration={1}
            className="text-4xl font-bold count-up-text"
            startWhen={true}
          />
          <p class="text-md">Jahre Tradition</p>
        </div>
      </div>

      <div class="col-span-12 md:col-span-3">
        <div
          class="bg-[var(--color-bg-light)] shadow-md flex flex-col items-center justify-center py-8 h-[100%] counter-card"
        >
          <CountUp
            client:visible
            from={0}
            to={6}
            separator=","
            direction="up"
            duration={1}
            className="font-bold  count-up-text"
            startWhen={true}
          />
          <p class="text-md">Events pro Jahr</p>
        </div>
      </div>
    </div>
  </div>

  <div class="h-[100px]"></div>

  <div class="container mx-auto px-4">
    <h2 class="text-center mb-4">Unsere Gewässer</h2>
    <p class="text-center mb-10 text-gray-500">
      Entdecke die Vielfalt unserer Angelgewässer - zwei Paradiese für jeden
      Angler.
    </p>
    <div class="grid grid-cols-12 gap-6">
      <!-- Karte 1 -->
      <div class="col-span-12 md:col-span-6">
        <div
          class="rounded-xl border border-gray-200 bg-white shadow-sm hover:shadow-md transition-shadow overflow-hidden h-full"
        >
          <div class="aspect-video overflow-hidden">
            <Image
              src={see1Img}
              alt="See 1"
              class="w-full h-full object-cover"
            />
          </div>
          <div class="p-5">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-xl font-semibold">Alter Badeweiher Burk</h3>
              <span
                class="px-2.5 py-0.5 rounded-full text-xs font-semibold bg-[#d1e5e3] text-[var(--color-secondary)]"
                >Stillgewässer</span
              >
            </div>
            <p class="text-sm text-gray-500 mb-4 leading-relaxed">
              Unser Hauptgewässer – ein idyllischer See umgeben von Wald und
              Wiesen. Ideal für Ansitz- und Friedfischangeln.
            </p>
            <div class="flex flex-wrap gap-1.5 mb-3">
              {
                ["Karpfen", "Hecht", "Zander", "Schleie", "Rotauge", "Barsch", "Forelle"].map(
                  (f) => (
                    <span class="px-2.5 py-0.5 rounded-full border border-gray-200 text-xs text-[var(--color-dark)]">
                      {f}
                    </span>
                  ),
                )
              }
            </div>
          </div>
        </div>
      </div>

      <!-- Karte 2 -->
      <div class="col-span-12 md:col-span-6">
        <div
          class="rounded-xl border border-gray-200 bg-white shadow-sm hover:shadow-md transition-shadow overflow-hidden h-full"
        >
          <div class="aspect-video overflow-hidden">
            <Image
              src={see2Img}
              alt="See 2"
              class="w-full h-full object-cover"
            />
          </div>
          <div class="p-5">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-xl font-semibold">Mittlerer Helingweiher</h3>
              <span
                class="px-2.5 py-0.5 rounded-full text-xs font-semibold bg-[#d1e5e3] text-[var(--color-secondary)]"
                >Stillgewässer</span
              >
            </div>
            <p class="text-sm text-gray-500 mb-4 leading-relaxed">
              Ein ruhig gelegenes Gewässer - Perfekt für jeden der eine Auszeit beim Angeln sucht!
            </p>
            <div class="flex flex-wrap gap-1.5 mb-3">
              {
                ["Karpfen", "Hecht", "Rotauge", "Graskarpfen"].map((f) => (
                  <span class="px-2.5 py-0.5 rounded-full border border-gray-200 text-xs text-[var(--color-dark)]">
                    {f}
                  </span>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="h-[150px]"></div>

  <div class="bg-[var(--color-bg-light)]">
    <div class="h-[100px]"></div>
    <div class="container mx-auto px-4">
      <h2 class="text-center mb-4">Unsere Werte</h2>
      <p class="text-center mb-10 text-gray-500">
        Diese Grundsätze leiten unser Handeln – am Wasser und darüber hinaus.
      </p>
      <div class="grid grid-cols-12 gap-6">
        <div class="col-span-12 md:col-span-6 xl:col-span-3">
          <div class="bg-gray-100 shadow h-[100%] p-6 rounded-lg text-center">
            <div class="card-icon">
              <i class="fa-solid fa-tree"></i>
            </div>
            <h3 class="font-bold mb-4 mt-6">Naturschutz</h3>
            <p>
              Wir setzen uns aktiv für den Erhalt unserer Gewässer und die
              heimische Tierwelt ein.
            </p>
          </div>
        </div>
        <div class="col-span-12 md:col-span-6 xl:col-span-3">
          <div class="bg-gray-100 shadow h-[100%] p-6 rounded-lg text-center">
            <div class="card-icon">
              <i class="fa-solid fa-heart"></i>
            </div>
            <h3 class="font-bold mb-4 mt-6">Leidenschaft</h3>
            <p>
              Angeln ist mehr als ein Hobby – es ist unsere gemeinsame
              Leidenschaft.
            </p>
          </div>
        </div>
        <div class="col-span-12 md:col-span-6 xl:col-span-3">
          <div class="bg-gray-100 shadow h-[100%] p-6 rounded-lg text-center">
            <div class="card-icon">
              <i class="fa-solid fa-hand-holding-heart"></i>
            </div>

            <h3 class="font-bold mb-4 mt-6">Förderung</h3>
            <p>
              Vom Anfänger bis zum Profi – wir fördern jeden auf seinem Weg.
            </p>
          </div>
        </div>
        <div class="col-span-12 md:col-span-6 xl:col-span-3">
          <div class="bg-gray-100 shadow h-[100%] p-6 rounded-lg text-center">
            <div class="card-icon">
              <i class="fa-solid fa-leaf"></i>
            </div>
            <h3 class="font-bold mb-4 mt-6">Nachhaltigkeit</h3>
            <p>
              Verantwortungsvoller Umgang mit der Natur steht bei uns an erster
              Stelle.
            </p>
          </div>
        </div>
      </div>
    </div>
    <div class="h-[100px]"></div>
  </div>

  <div class="h-[150px]"></div>

  <div class="container mx-auto px-4">
    <h2 class="text-center mb-4">Was uns ausmacht</h2>
    <p class="text-center mb-10 text-gray-500">
      Mehr als nur ein Verein – wir leben Angeln mit Herz und Gemeinschaft.
    </p>
    <div class="grid grid-cols-12 gap-6">
      <div class="col-span-12 md:col-span-6 xl:col-span-3">
        <div
          class="bg-[var(--color-bg-light)] shadow h-[100%] p-6 rounded-lg text-center"
        >
          <div class="card-icon">
            <i class="fa-solid fa-fish"></i>
          </div>
          <h3 class="font-bold mb-4 mt-6">Gemeinschaft</h3>
          <p>
            Bei uns steht die Gemeinschaft im Mittelpunkt. Wir organisieren
            regelmäßige Treffen, gemeinsame Angelausflüge und gesellige Abende,
            um den Zusammenhalt zu stärken.
          </p>
        </div>
      </div>
      <div class="col-span-12 md:col-span-6 xl:col-span-3">
        <div
          class="bg-[var(--color-bg-light)] shadow h-[100%] p-6 rounded-lg text-center"
        >
          <div class="card-icon">
            <i class="fa-solid fa-leaf"></i>
          </div>
          <h3 class="font-bold mb-4 mt-6">Nachhaltigkeit</h3>
          <p>
            Wir setzen uns für nachhaltiges Angeln und den Schutz unserer
            Gewässer ein. Unsere Mitglieder lernen verantwortungsbewusste
            Fangmethoden und unterstützen Naturschutzprojekte.
          </p>
        </div>
      </div>
      <div class="col-span-12 md:col-span-6 xl:col-span-3">
        <div
          class="bg-[var(--color-bg-light)] shadow h-[100%] p-6 rounded-lg text-center"
        >
          <div class="card-icon">
            <i class="fa-solid fa-users"></i>
          </div>

          <h3 class="font-bold mb-4 mt-6">Vielfalt</h3>
          <p>
            Unser Verein ist offen für alle, unabhängig von Alter oder
            Erfahrung. Wir fördern den Austausch zwischen Jung und Alt und
            bieten vielfältige Aktivitäten für jeden Geschmack.
          </p>
        </div>
      </div>
      <div class="col-span-12 md:col-span-6 xl:col-span-3">
        <div
          class="bg-[var(--color-bg-light)] shadow h-[100%] p-6 rounded-lg text-center"
        >
          <div class="card-icon">
            <i class="fa-solid fa-lightbulb"></i>
          </div>
          <h3 class="font-bold mb-4 mt-6">Innovation</h3>
          <p>
            Wir fördern innovative Ansätze im Angeln und in der Vereinsarbeit.
            Neue Ideen und Technologien werden bei uns willkommen geheißen, um
            das Angelerlebnis kontinuierlich zu verbessern.
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="h-[150px]"></div>
  <BecomeMember title="Jetzt Mitglied werden" />

  <div class="h-[150px]"></div>
</Layout>
