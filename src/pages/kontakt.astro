---
import Layout from "../layouts/Layout.astro";
import Badge from "../components/Badge.astro";
---

<Layout
  title="Kontakt"
  description="Nimm Kontakt mit unserem Fischerverein auf und erfahre mehr über unsere Aktivitäten."
>
  <section class="bg-[var(--color-secondary)] text-white">
    <div class="h-[120px]"></div>
    <div class="container mx-auto px-4">
      <div class="w-full min-[992px]:max-w-[50%]">
        <h1 class="text-4xl font-bold mb-4">Kontakt</h1>
        <p class="text-lg mb-6">
          Wir freuen uns über dein Interesse an unserem Fischerverein! Wenn du
          Fragen hast, mehr über unsere Aktivitäten erfahren möchtest oder
          einfach nur mit uns in Kontakt treten willst, zögere nicht, uns zu
          kontaktieren. Unser Team steht dir gerne zur Verfügung und freut sich
          darauf, von dir zu hören.
        </p>
        <Badge text="Gemeinschaft" />
        <Badge text="Nachhaltigkeit" />
        <Badge text="Tradition" />
      </div>

      <div class="h-[120px]"></div>
    </div>
  </section>

  <section class="bg-[var(--color-bg-light)] overflow-hidden">
        <div class="h-[150px]"></div>
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-12 gap-6 lg:gap-10">
        <div class="col-span-12 lg:col-span-6">
          <div
            class="col-span-12 md:col-span-6 bg-white rounded-lg shadow-md border border-gray-100 p-8"
          >
            <h3 class="text-2xl font-semibold mb-1">Nachricht senden</h3>
            <p class="text-sm text-gray-500 mb-6">
              Wir melden uns so schnell wie möglich bei dir.
            </p>

            <form id="kontakt-form" class="space-y-4">
              <div class="grid grid-cols-2 gap-3">
                <div class="space-y-1">
                  <label class="text-xs font-medium text-gray-600"
                    >Vorname</label
                  >
                  <input
                    id="k-vorname"
                    type="text"
                    placeholder="Max"
                    class="w-full h-10 rounded border border-gray-200 bg-gray-50 px-3 text-sm focus:outline-none focus:bg-white focus:border-[var(--color-primary)] transition"
                  />
                </div>
                <div class="space-y-1">
                  <label class="text-xs font-medium text-gray-600"
                    >Nachname</label
                  >
                  <input
                    id="k-nachname"
                    type="text"
                    placeholder="Mustermann"
                    class="w-full h-10 rounded border border-gray-200 bg-gray-50 px-3 text-sm focus:outline-none focus:bg-white focus:border-[var(--color-primary)] transition"
                  />
                </div>
              </div>
              <div class="space-y-1">
                <label class="text-xs font-medium text-gray-600">E-Mail</label>
                <input
                  id="k-email"
                  type="email"
                  placeholder="max@beispiel.de"
                  class="w-full h-10 rounded border border-gray-200 bg-gray-50 px-3 text-sm focus:outline-none focus:bg-white focus:border-[var(--color-primary)] transition"
                />
              </div>
              <div class="space-y-1">
                <label class="text-xs font-medium text-gray-600"
                  >Telefon <span class="text-gray-400 font-normal"
                    >(optional)</span
                  ></label
                >
                <input
                  id="k-telefon"
                  type="tel"
                  placeholder="01234 / 567890"
                  class="w-full h-10 rounded border border-gray-200 bg-gray-50 px-3 text-sm focus:outline-none focus:bg-white focus:border-[var(--color-primary)] transition"
                />
              </div>
              <div class="space-y-1">
                <label class="text-xs font-medium text-gray-600">Betreff</label>
                <select
                  id="k-betreff"
                  class="w-full h-10 rounded border border-gray-200 bg-gray-50 px-3 text-sm text-gray-500 focus:outline-none focus:bg-white focus:border-[var(--color-primary)] transition"
                >
                  <option value="" disabled selected>Betreff wählen</option>
                  <option value="mitgliedschaft">Mitgliedschaft</option>
                  <!-- <option value="tageskarten">Tageskarten</option> -->
                  <option value="veranstaltung">Veranstaltung</option>
                  <option value="sonstiges">Sonstiges</option>
                </select>
              </div>
              <div class="space-y-1">
                <label class="text-xs font-medium text-gray-600"
                  >Nachricht</label
                >
                <textarea
                  id="k-nachricht"
                  rows="5"
                  placeholder="Wie können wir dir helfen?"
                  class="w-full rounded border border-gray-200 bg-gray-50 px-3 py-2.5 text-sm focus:outline-none focus:bg-white focus:border-[var(--color-primary)] transition resize-none"
                ></textarea>
              </div>

              <p id="k-error" class="text-sm text-red-500 hidden"></p>
              <p id="k-success" class="text-sm text-green-600 hidden"></p>

              <button
                type="submit"
                class="w-full py-3 bg-[var(--color-primary)] text-white rounded text-[0.9rem] font-semibold hover:bg-[var(--color-secondary)] shadow hover:shadow-md active:shadow-sm cursor-pointer transition-all duration-200 flex items-center justify-center gap-2"
              >
                <i class="fa-regular fa-paper-plane text-sm"></i>
                Nachricht senden
              </button>
            </form>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-6">
          <div class="space-y-6">
            <!-- Kontaktdaten -->
            <div
              class="pb-8"
            >
              <h3 class="text-2xl font-semibold mb-6">Kontaktdaten</h3>
              <div class="flex flex-col gap-4">
                <div class="flex items-center gap-4">
                  <div
                    class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-[#d1e5e3] text-[var(--color-secondary)]"
                  >
                    <i class="fa-solid fa-location-dot"></i>
                  </div>
                  <div>
                    <p
                      class="text-xs text-gray-400 font-medium uppercase tracking-wide"
                    >
                      Adresse
                    </p>
                    <p class="text-sm font-medium text-[var(--color-dark)]">
                      Stormstraße 2, 71691 Freiberg am Neckar
                    </p>
                  </div>
                </div>
                
                <div class="flex items-center gap-4">
                  <div
                    class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-[#d1e5e3] text-[var(--color-secondary)]"
                  >
                    <i class="fa-solid fa-envelope"></i>
                  </div>
                  <div>
                    <p
                      class="text-xs text-gray-400 font-medium uppercase tracking-wide"
                    >
                      E-Mail
                    </p>
                    <p class="text-sm font-medium text-[var(--color-dark)]">
                      info@fv-oberstenfeld-gronau.de
                    </p>
                  </div>
                </div>
              </div>
            </div>

           

            <!-- Quick-Links -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <button
                id="open-mitglied-modal"
                class="bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md hover:border-[var(--color-primary)] transition-all p-4 flex items-center gap-3 group text-left w-full"
              >
                <div
                  class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-[#d1e5e3] text-[var(--color-secondary)] group-hover:bg-[var(--color-primary)] group-hover:text-white transition-colors"
                >
                  <i class="fa-solid fa-users text-sm"></i>
                </div>
                <div>
                  <p class="text-sm font-semibold text-[var(--color-dark)]">
                    Mitglied werden
                  </p>
                  <p class="text-xs text-gray-400">Jetzt beitreten</p>
                </div>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
        <div class="h-[150px]"></div>
  </section>

  <!-- Modal: Mitglied werden -->
  <div id="mitglied-modal"
    class="fixed inset-0 z-50 flex items-center justify-center p-4 hidden"
    aria-modal="true" role="dialog">
    <!-- Backdrop -->
    <div id="modal-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

    <!-- Panel -->
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-lg max-h-[90vh] overflow-y-auto">
      <!-- Header -->
      <div class="bg-[var(--color-secondary)] rounded-t-2xl px-6 py-5 flex items-start justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-white/60 mb-1">Fischerverein Oberstenfeld Gronau e.V</p>
          <h2 class="text-xl font-bold text-white">Mitglied werden</h2>
        </div>
        <button id="close-mitglied-modal" class="text-white/70 hover:text-white transition mt-0.5">
          <i class="fa-solid fa-xmark text-xl"></i>
        </button>
      </div>

      <!-- Inhalt -->
      <div class="px-6 py-6 space-y-6">

        <!-- Voraussetzungen -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3">Voraussetzungen</p>
          <ul class="space-y-2">
            <li class="flex items-start gap-3">
              <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#d1e5e3] text-[var(--color-secondary)] mt-0.5">
                <i class="fa-solid fa-check text-xs"></i>
              </span>
              <p class="text-sm text-gray-700">Gültiger <strong>Fischereischein</strong> (Jahres- oder Jugendfischereischein)</p>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#d1e5e3] text-[var(--color-secondary)] mt-0.5">
                <i class="fa-solid fa-check text-xs"></i>
              </span>
              <p class="text-sm text-gray-700">Mindestalter <strong>14 Jahre</strong> (unter 18 Jahren mit Einverständnis der Eltern)</p>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#d1e5e3] text-[var(--color-secondary)] mt-0.5">
                <i class="fa-solid fa-check text-xs"></i>
              </span>
              <p class="text-sm text-gray-700">Bereitschaft zur aktiven <strong>Mitarbeit</strong> bei Vereinsaktivitäten</p>
            </li>
          </ul>
        </div>

        <hr class="border-gray-100" />

        <!-- Ablauf -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3">So wirst du Mitglied</p>
          <ol class="space-y-4">
            <li class="flex gap-4">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[var(--color-primary)] text-white text-xs font-bold">1</span>
              <div>
                <p class="text-sm font-semibold text-[var(--color-dark)]">Kontakt aufnehmen</p>
                <p class="text-xs text-gray-500 mt-0.5">Schreib uns über das Kontaktformular oder melde dich direkt per E-Mail.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[var(--color-primary)] text-white text-xs font-bold">2</span>
              <div>
                <p class="text-sm font-semibold text-[var(--color-dark)]">Aufnahme durch den Vorstand</p>
                <p class="text-xs text-gray-500 mt-0.5">Der Vorstand prüft den Antrag und bestätigt deine Aufnahme.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[var(--color-primary)] text-white text-xs font-bold">3</span>
              <div>
                <p class="text-sm font-semibold text-[var(--color-dark)]">Jahresbeitrag entrichten</p>
                <p class="text-xs text-gray-500 mt-0.5">Nach der Aufnahme wird der Jahresbeitrag fällig. Willkommen im Verein!</p>
              </div>
            </li>
          </ol>
        </div>

        <hr class="border-gray-100" />

        <!-- CTA -->
        <button
          id="modal-to-kontakt"
          class="w-full py-3 bg-[var(--color-primary)] text-white rounded-xl text-sm font-semibold hover:bg-[var(--color-secondary)] transition flex items-center justify-center gap-2">
          <i class="fa-regular fa-paper-plane text-sm"></i>
          Jetzt Kontakt aufnehmen
        </button>
      </div>
    </div>
  </div>
</Layout>

<script>
  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  const btn = document.querySelector<HTMLButtonElement>("#kontakt-form button[type=submit]");

  function resetBtn() {
    if (!btn) return;
    btn.disabled = false;
    btn.innerHTML = '<i class="fa-regular fa-paper-plane text-sm"></i> Nachricht senden';
  }

  document.getElementById("kontakt-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const vorname   = (document.getElementById("k-vorname")   as HTMLInputElement).value.trim();
    const nachname  = (document.getElementById("k-nachname")  as HTMLInputElement).value.trim() || null;
    const email     = (document.getElementById("k-email")     as HTMLInputElement).value.trim();
    const telefon   = (document.getElementById("k-telefon")   as HTMLInputElement).value.trim() || null;
    const betreff   = (document.getElementById("k-betreff")   as HTMLSelectElement).value;
    const nachricht = (document.getElementById("k-nachricht") as HTMLTextAreaElement).value.trim();
    const errEl = document.getElementById("k-error");
    const okEl  = document.getElementById("k-success");

    errEl?.classList.add("hidden");
    okEl?.classList.add("hidden");

    if (!vorname || !email || !betreff || !nachricht) {
      errEl!.textContent = "Bitte Vorname, E-Mail, Betreff und Nachricht ausfüllen.";
      errEl?.classList.remove("hidden");
      return;
    }

    if (btn) { btn.disabled = true; btn.textContent = "Wird gesendet…"; }

    const payload = { vorname, nachname, email, telefon, betreff, nachricht };

    // 1. In Supabase speichern (für Admin-Panel)
    try {
      await fetch(`${SUPABASE_URL}/rest/v1/kontakt_anfragen`, {
        method: "POST",
        headers: {
          apikey: SUPABASE_KEY,
          Authorization: `Bearer ${SUPABASE_KEY}`,
          "Content-Type": "application/json",
          Prefer: "return=minimal",
        },
        body: JSON.stringify(payload),
      });
    } catch { /* weiter, auch wenn Supabase fehlschlägt */ }

    // 2. E-Mail via Resend Edge Function
    try {
      const res = await fetch(`${SUPABASE_URL}/functions/v1/send-notification-email`, {
        method: "POST",
        headers: {
          apikey: SUPABASE_KEY,
          Authorization: `Bearer ${SUPABASE_KEY}`,
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ type: "kontakt", ...payload }),
      });

      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        throw new Error(data.error || res.status);
      }
    } catch (err: any) {
      errEl!.textContent = "Fehler beim Senden: " + err.message;
      errEl?.classList.remove("hidden");
      resetBtn();
      return;
    }

    okEl!.textContent = `Danke ${vorname}! Deine Nachricht wurde gesendet.`;
    okEl?.classList.remove("hidden");
    (e.target as HTMLFormElement).reset();
    resetBtn();
  });

  // Modal: Mitglied werden
  const modal    = document.getElementById('mitglied-modal')!;
  const backdrop = document.getElementById('modal-backdrop')!;

  function openModal() {
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
  }

  document.getElementById('open-mitglied-modal')?.addEventListener('click', openModal);
  document.getElementById('close-mitglied-modal')?.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);

  document.getElementById('modal-to-kontakt')?.addEventListener('click', () => {
    closeModal();
    (document.getElementById('k-betreff') as HTMLSelectElement).value = 'mitgliedschaft';
    const vorname = document.getElementById('k-vorname') as HTMLInputElement;
    vorname?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    setTimeout(() => vorname?.focus(), 400);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>
