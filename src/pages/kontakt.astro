---
import Layout from "../layouts/Layout.astro";
import Badge from "../components/Badge.astro";
---

<Layout
  title="Kontakt"
  description="Nimm Kontakt mit unserem Fischerverein auf und erfahre mehr über unsere Aktivitäten."
>
  <section class="bg-[var(--color-secondary)] text-white">
    <div class="h-[180px]"></div>
    <div class="container mx-auto px-4">
      <div class="w-full min-[992px]:max-w-[50%]">
        <h1 class="text-4xl font-bold mb-4">Kontakt</h1>
        <p class="text-lg mb-6">
          Wir freuen uns über dein Interesse an unserem Fischerverein! Wenn du
          Fragen hast, mehr über unsere Aktivitäten erfahren möchtest oder
          einfach nur mit uns in Kontakt treten willst, zögere nicht, uns zu
          kontaktieren. Unser Team steht dir gerne zur Verfügung und freut sich
          darauf, von dir zu hören.
        </p>
        <Badge text="Gemeinschaft" />
        <Badge text="Nachhaltigkeit" />
        <Badge text="Tradition" />
      </div>

      <div class="h-[120px]"></div>
    </div>
  </section>

  <section class="bg-[var(--color-bg-light)] overflow-hidden">
        <div class="h-[150px]"></div>
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-12 gap-6 lg:gap-10">
        <div class="col-span-12 lg:col-span-6">
          <div
            class="col-span-12 md:col-span-6 bg-white rounded-lg shadow-md border border-gray-100 p-8"
          >
            <h3 class="text-2xl font-semibold mb-1">Nachricht senden</h3>
            <p class="text-sm text-gray-500 mb-6">
              Wir melden uns so schnell wie möglich bei dir.
            </p>

            <form id="kontakt-form" class="space-y-4">
              <div class="grid grid-cols-2 gap-3">
                <div class="space-y-1">
                  <label class="text-xs font-medium text-gray-600"
                    >Vorname</label
                  >
                  <input
                    id="k-vorname"
                    type="text"
                    placeholder="Max"
                    class="w-full h-10 rounded border border-gray-200 bg-gray-50 px-3 text-sm focus:outline-none focus:bg-white focus:border-[var(--color-primary)] transition"
                  />
                </div>
                <div class="space-y-1">
                  <label class="text-xs font-medium text-gray-600"
                    >Nachname</label
                  >
                  <input
                    id="k-nachname"
                    type="text"
                    placeholder="Mustermann"
                    class="w-full h-10 rounded border border-gray-200 bg-gray-50 px-3 text-sm focus:outline-none focus:bg-white focus:border-[var(--color-primary)] transition"
                  />
                </div>
              </div>
              <div class="space-y-1">
                <label class="text-xs font-medium text-gray-600">E-Mail</label>
                <input
                  id="k-email"
                  type="email"
                  placeholder="max@beispiel.de"
                  class="w-full h-10 rounded border border-gray-200 bg-gray-50 px-3 text-sm focus:outline-none focus:bg-white focus:border-[var(--color-primary)] transition"
                />
              </div>
              <div class="space-y-1">
                <label class="text-xs font-medium text-gray-600"
                  >Telefon <span class="text-gray-400 font-normal"
                    >(optional)</span
                  ></label
                >
                <input
                  id="k-telefon"
                  type="tel"
                  placeholder="01234 / 567890"
                  class="w-full h-10 rounded border border-gray-200 bg-gray-50 px-3 text-sm focus:outline-none focus:bg-white focus:border-[var(--color-primary)] transition"
                />
              </div>
              <div class="space-y-1">
                <label class="text-xs font-medium text-gray-600">Betreff</label>
                <select
                  id="k-betreff"
                  class="w-full h-10 rounded border border-gray-200 bg-gray-50 px-3 text-sm text-gray-500 focus:outline-none focus:bg-white focus:border-[var(--color-primary)] transition"
                >
                  <option value="" disabled selected>Betreff wählen</option>
                  <option value="mitgliedschaft">Mitgliedschaft</option>
                  <option value="angelschein">Angelschein / Erlaubnis</option>
                  <option value="veranstaltung">Veranstaltung</option>
                  <option value="sonstiges">Sonstiges</option>
                </select>
              </div>
              <div class="space-y-1">
                <label class="text-xs font-medium text-gray-600"
                  >Nachricht</label
                >
                <textarea
                  id="k-nachricht"
                  rows="5"
                  placeholder="Wie können wir dir helfen?"
                  class="w-full rounded border border-gray-200 bg-gray-50 px-3 py-2.5 text-sm focus:outline-none focus:bg-white focus:border-[var(--color-primary)] transition resize-none"
                ></textarea>
              </div>

              <p id="k-error" class="text-sm text-red-500 hidden"></p>
              <p id="k-success" class="text-sm text-green-600 hidden"></p>

              <button
                type="submit"
                class="w-full py-3 bg-[var(--color-primary)] text-white rounded text-[0.9rem] font-semibold hover:bg-[var(--color-secondary)] shadow hover:shadow-md active:shadow-sm cursor-pointer transition-all duration-200 flex items-center justify-center gap-2"
              >
                <i class="fa-regular fa-paper-plane text-sm"></i>
                Nachricht senden
              </button>
            </form>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-6">
          <div class="space-y-6">
            <!-- Kontaktdaten -->
            <div
              class="pb-8"
            >
              <h3 class="text-2xl font-semibold mb-6">Kontaktdaten</h3>
              <div class="flex flex-col gap-4">
                <div class="flex items-center gap-4">
                  <div
                    class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-[#d1e5e3] text-[var(--color-secondary)]"
                  >
                    <i class="fa-solid fa-location-dot"></i>
                  </div>
                  <div>
                    <p
                      class="text-xs text-gray-400 font-medium uppercase tracking-wide"
                    >
                      Adresse
                    </p>
                    <p class="text-sm font-medium text-[var(--color-dark)]">
                      Musterstraße 1, 12345 Musterstadt
                    </p>
                  </div>
                </div>
                <div class="flex items-center gap-4">
                  <div
                    class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-[#d1e5e3] text-[var(--color-secondary)]"
                  >
                    <i class="fa-solid fa-phone"></i>
                  </div>
                  <div>
                    <p
                      class="text-xs text-gray-400 font-medium uppercase tracking-wide"
                    >
                      Telefon
                    </p>
                    <p class="text-sm font-medium text-[var(--color-dark)]">
                      01234 / 567890
                    </p>
                  </div>
                </div>
                <div class="flex items-center gap-4">
                  <div
                    class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-[#d1e5e3] text-[var(--color-secondary)]"
                  >
                    <i class="fa-solid fa-envelope"></i>
                  </div>
                  <div>
                    <p
                      class="text-xs text-gray-400 font-medium uppercase tracking-wide"
                    >
                      E-Mail
                    </p>
                    <p class="text-sm font-medium text-[var(--color-dark)]">
                      info@fischerverein.de
                    </p>
                  </div>
                </div>
                <div class="flex items-center gap-4">
                  <div
                    class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-[#d1e5e3] text-[var(--color-secondary)]"
                  >
                    <i class="fa-regular fa-clock"></i>
                  </div>
                  <div>
                    <p
                      class="text-xs text-gray-400 font-medium uppercase tracking-wide"
                    >
                      Erreichbarkeit
                    </p>
                    <p class="text-sm font-medium text-[var(--color-dark)]">
                      Mo–Fr: 9:00 – 17:00 Uhr
                    </p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Google Maps -->
            <div
              class="aspect-video rounded-lg mb-8 bg-gray-100 border border-gray-200 flex items-center justify-center overflow-hidden shadow-sm"
            >
              <div class="text-center">
                <i
                  class="fa-solid fa-map-location-dot text-3xl text-gray-300 mb-2"
                ></i>
                <p class="text-sm text-gray-400">Google Maps</p>
              </div>
            </div>

            <!-- Quick-Links -->
            <div class="grid grid-cols-2 gap-3">
              <a
                href="/kontakt"
                class="bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md hover:border-[var(--color-primary)] transition-all p-4 flex items-center gap-3 group"
              >
                <div
                  class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-[#d1e5e3] text-[var(--color-secondary)] group-hover:bg-[var(--color-primary)] group-hover:text-white transition-colors"
                >
                  <i class="fa-solid fa-users text-sm"></i>
                </div>
                <div>
                  <p class="text-sm font-semibold text-[var(--color-dark)]">
                    Mitglied werden
                  </p>
                  <p class="text-xs text-gray-400">Jetzt beitreten</p>
                </div>
              </a>
              <a
                href="/kontakt"
                class="bg-white rounded-xl border border-gray-100 shadow-sm hover:shadow-md hover:border-[var(--color-primary)] transition-all p-4 flex items-center gap-3 group"
              >
                <div
                  class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-[#d1e5e3] text-[var(--color-secondary)] group-hover:bg-[var(--color-primary)] group-hover:text-white transition-colors"
                >
                  <i class="fa-solid fa-file-lines text-sm"></i>
                </div>
                <div>
                  <p class="text-sm font-semibold text-[var(--color-dark)]">
                    Downloads
                  </p>
                  <p class="text-xs text-gray-400">Formulare &amp; Satzung</p>
                </div>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
        <div class="h-[150px]"></div>
  </section>
</Layout>

<script>
  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  const btn = document.querySelector<HTMLButtonElement>("#kontakt-form button[type=submit]");

  function resetBtn() {
    if (!btn) return;
    btn.disabled = false;
    btn.innerHTML = '<i class="fa-regular fa-paper-plane text-sm"></i> Nachricht senden';
  }

  document.getElementById("kontakt-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const vorname   = (document.getElementById("k-vorname")   as HTMLInputElement).value.trim();
    const nachname  = (document.getElementById("k-nachname")  as HTMLInputElement).value.trim() || null;
    const email     = (document.getElementById("k-email")     as HTMLInputElement).value.trim();
    const telefon   = (document.getElementById("k-telefon")   as HTMLInputElement).value.trim() || null;
    const betreff   = (document.getElementById("k-betreff")   as HTMLSelectElement).value;
    const nachricht = (document.getElementById("k-nachricht") as HTMLTextAreaElement).value.trim();
    const errEl = document.getElementById("k-error");
    const okEl  = document.getElementById("k-success");

    errEl?.classList.add("hidden");
    okEl?.classList.add("hidden");

    if (!vorname || !email || !betreff || !nachricht) {
      errEl!.textContent = "Bitte Vorname, E-Mail, Betreff und Nachricht ausfüllen.";
      errEl?.classList.remove("hidden");
      return;
    }

    if (btn) { btn.disabled = true; btn.textContent = "Wird gesendet…"; }

    const payload = { vorname, nachname, email, telefon, betreff, nachricht };

    // 1. In Supabase speichern (für Admin-Panel)
    try {
      await fetch(`${SUPABASE_URL}/rest/v1/kontakt_anfragen`, {
        method: "POST",
        headers: {
          apikey: SUPABASE_KEY,
          Authorization: `Bearer ${SUPABASE_KEY}`,
          "Content-Type": "application/json",
          Prefer: "return=minimal",
        },
        body: JSON.stringify(payload),
      });
    } catch { /* weiter, auch wenn Supabase fehlschlägt */ }

    // 2. E-Mail via Resend Edge Function
    try {
      const res = await fetch(`${SUPABASE_URL}/functions/v1/send-notification-email`, {
        method: "POST",
        headers: {
          apikey: SUPABASE_KEY,
          Authorization: `Bearer ${SUPABASE_KEY}`,
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ type: "kontakt", ...payload }),
      });

      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        throw new Error(data.error || res.status);
      }
    } catch (err: any) {
      errEl!.textContent = "Fehler beim Senden: " + err.message;
      errEl?.classList.remove("hidden");
      resetBtn();
      return;
    }

    okEl!.textContent = `Danke ${vorname}! Deine Nachricht wurde gesendet.`;
    okEl?.classList.remove("hidden");
    (e.target as HTMLFormElement).reset();
    resetBtn();
  });
</script>
