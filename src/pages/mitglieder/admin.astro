---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Admin Dashboard">
  <div class="container mx-auto px-4 py-12">
    <p class="mb-2 text-3xl font-semibold">Admin Dashboard</p>
    <p class="text-gray-500 mb-10">Mitgliederverwaltung</p>

    <!-- Neuen User erstellen -->
    <div class="bg-white shadow rounded-xl p-6 mb-10">
      <h2 class="h3 mb-6">Neues Mitglied erstellen</h2>
      <form id="create-user-form" class="grid grid-cols-12 gap-4">
        <div class="col-span-12 md:col-span-3">
          <label class="block text-sm font-medium text-gray-700 mb-1"
            >Name</label
          >
          <input
            id="new-name"
            type="text"
            placeholder="Max Mustermann"
            class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-[var(--color-primary)]"
          />
        </div>
        <div class="col-span-12 md:col-span-3">
          <label class="block text-sm font-medium text-gray-700 mb-1"
            >Benutzername</label
          >
          <input
            id="new-username"
            type="text"
            placeholder="maxmustermann"
            class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-[var(--color-primary)]"
          />
        </div>
        <div class="col-span-12 md:col-span-3">
          <label class="block text-sm font-medium text-gray-700 mb-1"
            >E-Mail</label
          >
          <input
            id="new-email"
            type="email"
            placeholder="max@email.de"
            class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-[var(--color-primary)]"
          />
        </div>

        <div class="col-span-12 md:col-span-3">
          <label class="block text-sm font-medium text-gray-700 mb-1"
            >Passwort</label
          >
          <div class="relative">
            <input
              id="new-password"
              type="password"
              placeholder="••••••••"
              class="w-full border border-gray-300 rounded-md px-3 py-2 pr-10 text-sm focus:outline-none focus:border-[var(--color-primary)]"
            />
            <button
              type="button"
              id="toggle-new-password"
              class="absolute inset-y-0 right-0 flex items-center px-3 text-gray-400 hover:text-gray-600"
              aria-label="Passwort anzeigen"
            >
              <svg id="new-eye-icon" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
              <svg id="new-eye-off-icon" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
              </svg>
            </button>
          </div>
        </div>

        <div class="col-span-12 md:col-span-3">
          <label class="block text-sm font-medium text-gray-700 mb-1"
            >Rolle</label
          >
          <select
            id="new-role"
            class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-[var(--color-primary)]"
          >
            <option value="user">Mitglied</option>
            <option value="moderator">Moderator</option>
            <option value="admin">Admin</option>
          </select>
        </div>

        <div class="col-span-12 flex items-end">
          <button
            type="submit"
            class="bg-[var(--color-primary)] text-white px-6 py-2 rounded-md font-semibold hover:opacity-90 transition"
          >
            Erstellen
          </button>
        </div>
        <p id="create-error" class="col-span-12 text-red-500 text-sm hidden">
        </p>
        <p
          id="create-success"
          class="col-span-12 text-green-600 text-sm hidden"
        >
        </p>
      </form>
    </div>

    <!-- Termine -->
    <div class="bg-white shadow rounded-xl p-6 mb-10">
      <h2 class="h3 mb-6">Termin hinzufügen</h2>
      <form id="create-termin-form" class="grid grid-cols-12 gap-4">
        <div class="col-span-12 md:col-span-4">
          <label class="block text-sm font-medium text-gray-700 mb-1">Titel</label>
          <input id="t-titel" type="text" placeholder="Jahreshauptversammlung"
            class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-[var(--color-primary)]" />
        </div>
        <div class="col-span-12 md:col-span-2">
          <label class="block text-sm font-medium text-gray-700 mb-1">Datum</label>
          <input id="t-datum" type="date"
            class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-[var(--color-primary)]" />
        </div>
        <div class="col-span-12 md:col-span-2">
          <label class="block text-sm font-medium text-gray-700 mb-1">Uhrzeit (optional)</label>
          <input id="t-uhrzeit" type="time"
            class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-[var(--color-primary)]" />
        </div>
        <div class="col-span-12 md:col-span-4">
          <label class="block text-sm font-medium text-gray-700 mb-1">Ort (optional)</label>
          <input id="t-ort" type="text" placeholder="Vereinsheim"
            class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-[var(--color-primary)]" />
        </div>
        <div class="col-span-12">
          <label class="block text-sm font-medium text-gray-700 mb-1">Beschreibung (optional)</label>
          <textarea id="t-beschreibung" rows="2" placeholder="Weitere Informationen..."
            class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-[var(--color-primary)]"></textarea>
        </div>
        <div class="col-span-12">
          <label class="block text-sm font-medium text-gray-700 mb-1">Badges (optional)</label>
          <div id="create-termin-preview" class="flex flex-wrap gap-1.5 mb-2 min-h-[28px]"></div>
          <div class="flex gap-2 flex-wrap">
            <input id="create-termin-tag-text" type="text" placeholder="z.B. Pflichttermin"
              class="flex-1 border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-[var(--color-primary)]" />
            <select id="create-termin-tag-color"
              class="border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-[var(--color-primary)]">
              <option value="primary">Grün</option>
              <option value="dark">Dunkel</option>
              <option value="gray">Grau</option>
              <option value="blue">Blau</option>
              <option value="orange">Orange</option>
              <option value="red">Rot</option>
            </select>
            <button type="button" onclick="addTag('create-termin')"
              class="bg-gray-100 hover:bg-gray-200 text-gray-700 px-4 py-2 rounded-md text-sm font-medium transition whitespace-nowrap">+ Badge</button>
          </div>
        </div>
        <div class="col-span-12 flex items-center gap-4">
          <button type="submit"
            class="bg-[var(--color-primary)] text-white px-6 py-2 rounded-md font-semibold hover:opacity-90 transition">
            Termin erstellen
          </button>
          <p id="termin-error" class="text-red-500 text-sm hidden"></p>
          <p id="termin-success" class="text-green-600 text-sm hidden"></p>
        </div>
      </form>
    </div>

    <div class="bg-white shadow rounded-xl p-6 mb-10">
      <h2 class="h3 mb-6">Alle Termine</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
          <thead class="bg-gray-100 text-gray-600">
            <tr>
              <th class="px-4 py-3 rounded-l-lg">Datum</th>
              <th class="px-4 py-3">Titel</th>
              <th class="px-4 py-3">Uhrzeit</th>
              <th class="px-4 py-3">Ort</th>
              <th class="px-4 py-3 rounded-r-lg">Aktionen</th>
            </tr>
          </thead>
          <tbody id="termin-table-body">
            <tr><td colspan="5" class="px-4 py-6 text-center text-gray-400">Lädt...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Kontaktanfragen -->
    <div class="bg-white shadow rounded-xl p-6 mb-10">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h2 class="h3">Kontaktanfragen</h2>
        </div>
        <span id="anfragen-badge" class="hidden px-2.5 py-1 rounded-full text-xs font-semibold bg-red-100 text-red-600"></span>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
          <thead class="bg-gray-100 text-gray-600">
            <tr>
              <th class="px-4 py-3 rounded-l-lg">Datum</th>
              <th class="px-4 py-3">Name</th>
              <th class="px-4 py-3">E-Mail</th>
              <th class="px-4 py-3">Betreff</th>
              <th class="px-4 py-3">Nachricht</th>
              <th class="px-4 py-3 rounded-r-lg">Aktionen</th>
            </tr>
          </thead>
          <tbody id="anfragen-table-body">
            <tr><td colspan="6" class="px-4 py-6 text-center text-gray-400">Lädt...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Nachricht-Modal -->
    <div id="msg-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm p-4">
      <div class="bg-white rounded-xl shadow-xl max-w-lg w-full p-6 relative">
        <button onclick="closeMsgModal()" class="absolute top-3 right-4 text-gray-400 hover:text-gray-700 text-xl font-bold leading-none">&times;</button>
        <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-1" id="modal-meta"></p>
        <h3 class="text-lg font-semibold mb-3" id="modal-subject"></h3>
        <p class="text-sm text-gray-700 whitespace-pre-wrap" id="modal-body"></p>
      </div>
    </div>

    <!-- User Liste -->
    <div class="bg-white shadow rounded-xl p-6">
      <h2 class="h3 mb-6">Alle Mitglieder</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
          <thead class="bg-gray-100 text-gray-600">
            <tr>
              <th class="px-4 py-3 rounded-l-lg">Name</th>
              <th class="px-4 py-3">Benutzername</th>
              <th class="px-4 py-3">E-Mail</th>
              <th class="px-4 py-3">Rolle</th>
              <th class="px-4 py-3">Erstellt am</th>
              <th class="px-4 py-3 text-center">Beitrag</th>
              <th class="px-4 py-3 rounded-r-lg">Aktionen</th>
            </tr>
          </thead>
          <tbody id="user-table-body">
            <tr>
              <td colspan="7" class="px-4 py-6 text-center text-gray-400">Lädt...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  document.getElementById("toggle-new-password")?.addEventListener("click", () => {
    const input = document.getElementById("new-password") as HTMLInputElement;
    const eyeIcon = document.getElementById("new-eye-icon");
    const eyeOffIcon = document.getElementById("new-eye-off-icon");
    const isHidden = input.type === "password";
    input.type = isHidden ? "text" : "password";
    eyeIcon?.classList.toggle("hidden", isHidden);
    eyeOffIcon?.classList.toggle("hidden", !isHidden);
  });

  function showToast(msg: string, type: 'success' | 'error' = 'success') {
    const isError = type === 'error';
    const div = document.createElement('div');
    div.style.cssText = [
      'position:fixed;bottom:24px;right:24px;z-index:9999',
      'padding:13px 20px;border-radius:12px',
      `background:${isError ? '#dc2626' : '#16a34a'};color:#fff`,
      'font-size:14px;font-weight:500;font-family:inherit',
      'display:flex;align-items:center;gap:10px',
      'box-shadow:0 4px 20px rgba(0,0,0,.18)',
      'transform:translateY(10px);opacity:0',
      'transition:opacity .25s ease,transform .25s ease',
      'max-width:360px;line-height:1.4',
    ].join(';');
    div.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0">${
      isError
        ? '<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>'
        : '<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5-4-4 1.41-1.41L10 13.67l6.59-6.59L18 8.5l-8 8z"/>'
    }</svg><span>${msg}</span>`;
    document.body.appendChild(div);
    requestAnimationFrame(() => requestAnimationFrame(() => {
      div.style.opacity = '1';
      div.style.transform = 'translateY(0)';
    }));
    setTimeout(() => {
      div.style.opacity = '0';
      div.style.transform = 'translateY(10px)';
      setTimeout(() => div.remove(), 300);
    }, 4500);
  }

  async function sendEmailNotification(payload: Record<string, unknown>) {
    try {
      const res = await fetch(`${SUPABASE_URL}/functions/v1/send-notification-email`, {
        method: 'POST',
        headers: {
          'apikey': SUPABASE_KEY,
          'Authorization': `Bearer ${getJwt()}`,
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || res.status);
      showToast(`E-Mail wurde an ${data.sent} Mitglieder gesendet`);
    } catch (err: any) {
      showToast('E-Mail konnte nicht gesendet werden: ' + err.message, 'error');
    }
  }

  function getJwt() {
    const storageKey = Object.keys(localStorage).find(k => k.includes('auth-token'));
    const stored = storageKey ? JSON.parse(localStorage.getItem(storageKey) || '{}') : {};
    return stored?.access_token || SUPABASE_KEY;
  }

  function handleUnauthorized(res: Response) {
    if (res.status === 401) {
      window.location.replace('/mitglieder/login');
      return true;
    }
    return false;
  }

  function headers() {
    return {
      'apikey': SUPABASE_KEY,
      'Authorization': `Bearer ${getJwt()}`,
      'Content-Type': 'application/json',
    };
  }

  let usersCache: any[] = [];
  let editingUserId: string | null = null;

  function escapeHtml(value: string) {
    return value
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
  }

  function tagClass(color: string) {
    const map: Record<string, string> = {
      primary: 'bg-[#d1e5e3] text-[var(--color-secondary)]',
      dark: 'bg-gray-200 text-gray-800',
      gray: 'bg-gray-100 text-gray-500',
      blue: 'bg-blue-100 text-blue-700',
      orange: 'bg-orange-100 text-orange-700',
      red: 'bg-red-100 text-red-600',
    };
    return map[color] || map['primary'];
  }

  function tagsDisplayHtml(tags: any[]) {
    if (!tags?.length) return '';
    return `<div class="flex flex-wrap gap-1 mt-1">${tags.map(t =>
      `<span class="px-2 py-0.5 rounded-full text-xs font-medium ${tagClass(t.color)}">${escapeHtml(t.text)}</span>`
    ).join('')}</div>`;
  }

  const tagsStore = new Map<string, any[]>();

  function addTag(prefix: string) {
    const textEl = document.getElementById(`${prefix}-tag-text`) as HTMLInputElement;
    const colorEl = document.getElementById(`${prefix}-tag-color`) as HTMLSelectElement;
    const text = textEl?.value.trim();
    if (!text) return;
    const color = colorEl?.value || 'primary';
    if (!tagsStore.has(prefix)) tagsStore.set(prefix, []);
    tagsStore.get(prefix)!.push({ text, color });
    textEl.value = '';
    refreshTagEditor(prefix);
  }

  function removeTag(prefix: string, index: number) {
    const tags = tagsStore.get(prefix);
    if (!tags) return;
    tags.splice(index, 1);
    refreshTagEditor(prefix);
  }

  function refreshTagEditor(prefix: string) {
    const tags = tagsStore.get(prefix) || [];
    const preview = document.getElementById(`${prefix}-preview`);
    if (!preview) return;
    preview.innerHTML = tags.map((t, i) =>
      `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium ${tagClass(t.color)}">
        ${escapeHtml(t.text)}
        <button type="button" onclick="removeTag('${prefix}',${i})" class="ml-0.5 hover:opacity-70 leading-none">×</button>
      </span>`
    ).join('');
  }

  async function deleteUser(id: string) {
    const user = usersCache.find((u) => u.id === id);
    const label = user?.full_name || user?.email || "dieses Mitglied";

    if (!confirm(`Mitglied "${label}" wirklich löschen?`)) return;

    const profileRes = await fetch(`${SUPABASE_URL}/rest/v1/profiles?id=eq.${id}`, {
      method: 'DELETE',
      headers: headers(),
    });
    if (!profileRes.ok) {
      showToast('Fehler beim Löschen des Profils: ' + profileRes.status, 'error');
      return;
    }

    const rpcRes = await fetch(`${SUPABASE_URL}/rest/v1/rpc/delete_user_completely`, {
      method: 'POST',
      headers: headers(),
      body: JSON.stringify({ user_id: id }),
    });
    if (!rpcRes.ok) {
      showToast('Fehler beim Löschen des Auth-Users: ' + rpcRes.status, 'error');
      return;
    }

    loadUsers();
    showToast(`Mitglied "${label}" wurde gelöscht`);
  }

  function startEditUser(id: string) {
    editingUserId = id;
    loadUsers();
  }

  function cancelEditUser() {
    editingUserId = null;
    loadUsers();
  }

  async function saveUser(id: string) {
    const user = usersCache.find((u) => u.id === id);
    if (!user) return;

    const nameEl = document.getElementById(`edit-name-${id}`) as HTMLInputElement | null;
    const usernameEl = document.getElementById(`edit-username-${id}`) as HTMLInputElement | null;
    const roleEl = document.getElementById(`edit-role-${id}`) as HTMLSelectElement | null;

    const name = nameEl?.value.trim() || "";
    const username = usernameEl?.value.trim() || "";
    const role = roleEl?.value || "user";

    if (!username) {
      alert("Benutzername ist erforderlich");
      return;
    }

    const rpcRes = await fetch(`${SUPABASE_URL}/rest/v1/rpc/create_or_update_profile`, {
      method: 'POST',
      headers: headers(),
      body: JSON.stringify({
        target_id: user.id,
        target_email: user.email,
        target_name: name,
        target_username: username,
        target_role: role,
      }),
    });

    if (!rpcRes.ok) {
      const rpcErrorText = await rpcRes.text();
      alert(`Profil konnte nicht gespeichert werden: ${rpcErrorText || rpcRes.status}`);
      return;
    }

    editingUserId = null;
    loadUsers();
    showToast('Mitglied wurde gespeichert');
  }

  async function toggleBeitrag(id: string, checked: boolean) {
    const year = checked ? new Date().getFullYear() : null;
    const res = await fetch(`${SUPABASE_URL}/rest/v1/profiles?id=eq.${id}`, {
      method: 'PATCH',
      headers: { ...headers(), 'Prefer': 'return=minimal' },
      body: JSON.stringify({ beitrag_bezahlt_jahr: year }),
    });
    if (!res.ok) {
      showToast('Fehler beim Aktualisieren: ' + res.status, 'error');
      const cb = document.getElementById(`beitrag-cb-${id}`) as HTMLInputElement;
      if (cb) cb.checked = !checked;
      return;
    }
    const user = usersCache.find(u => u.id === id);
    if (user) user.beitrag_bezahlt_jahr = year;
    showToast(checked ? 'Jahresbeitrag als bezahlt markiert' : 'Jahresbeitrag zurückgesetzt');
  }

  (window as any).deleteUser = deleteUser;
  (window as any).startEditUser = startEditUser;
  (window as any).cancelEditUser = cancelEditUser;
  (window as any).saveUser = saveUser;
  (window as any).toggleBeitrag = toggleBeitrag;

  async function loadUsers() {
    const tbody = document.getElementById("user-table-body");
    if (!tbody) return;

    let data: any[];
    try {
      const res = await fetch(`${SUPABASE_URL}/rest/v1/profiles?select=*&order=created_at.desc`, {
        headers: headers(),
      });
      if (handleUnauthorized(res)) return;
      data = await res.json();
    } catch(e: any) {
      tbody.innerHTML = `<tr><td colspan="7" class="px-4 py-6 text-center text-red-500">Fehler: ${e.message}</td></tr>`;
      return;
    }

    usersCache = Array.isArray(data) ? data : [];

    if (!Array.isArray(data) || !data.length) {
      tbody.innerHTML = `<tr><td colspan="7" class="px-4 py-6 text-center text-gray-400">Keine Mitglieder gefunden.</td></tr>`;
      return;
    }

    const currentYear = new Date().getFullYear();

    tbody.innerHTML = data.map((user) => {
      const isEditing = editingUserId === user.id;
      const safeName = escapeHtml(user.full_name || "");
      const safeUsername = escapeHtml(user.username || "");
      const safeEmail = escapeHtml(user.email || "");
      const beitragBezahlt = user.beitrag_bezahlt_jahr === currentYear;

      if (isEditing) {
        return `
      <tr class="border-t border-gray-100 bg-gray-50/60">
        <td class="px-4 py-3">
          <input id="edit-name-${user.id}" type="text" value="${safeName}" class="w-full border border-gray-300 rounded-md px-2 py-1 text-sm" />
        </td>
        <td class="px-4 py-3">
          <input id="edit-username-${user.id}" type="text" value="${safeUsername}" class="w-full border border-gray-300 rounded-md px-2 py-1 text-sm" />
        </td>
        <td class="px-4 py-3">${safeEmail || "—"}</td>
        <td class="px-4 py-3">
          <select id="edit-role-${user.id}" class="w-full border border-gray-300 rounded-md px-2 py-1 text-sm">
            <option value="user" ${user.role === "user" ? "selected" : ""}>Mitglied</option>
            <option value="moderator" ${user.role === "moderator" ? "selected" : ""}>Moderator</option>
            <option value="admin" ${user.role === "admin" ? "selected" : ""}>Admin</option>
          </select>
        </td>
        <td class="px-4 py-3 text-gray-400">${new Date(user.created_at).toLocaleDateString("de-DE")}</td>
        <td class="px-4 py-3 text-center">
          <input type="checkbox" id="beitrag-cb-${user.id}" ${beitragBezahlt ? "checked" : ""}
            onchange="toggleBeitrag('${user.id}', this.checked)"
            class="w-4 h-4 accent-[var(--color-primary)] cursor-pointer" />
        </td>
        <td class="px-4 py-3 whitespace-nowrap">
          <button onclick="saveUser('${user.id}')" class="text-[var(--color-primary)] hover:opacity-80 text-sm font-medium mr-3">Speichern</button>
          <button onclick="cancelEditUser()" class="text-gray-600 hover:text-gray-900 text-sm font-medium">Abbrechen</button>
        </td>
      </tr>`;
      }

      return `
      <tr class="border-t border-gray-100">
        <td class="px-4 py-3">${user.full_name || "—"}</td>
        <td class="px-4 py-3">${user.username || "—"}</td>
        <td class="px-4 py-3">${user.email || "—"}</td>
        <td class="px-4 py-3">
          <span class="px-2 py-1 rounded-full text-xs font-medium ${
            user.role === "admin" ? "bg-[#d1e5e3] text-[var(--color-primary)]" :
            user.role === "moderator" ? "bg-blue-100 text-blue-700" :
            "bg-gray-100 text-gray-600"
          }">
            ${user.role === "admin" ? "Admin" : user.role === "moderator" ? "Moderator" : "Mitglied"}
          </span>
        </td>
        <td class="px-4 py-3 text-gray-400">${new Date(user.created_at).toLocaleDateString("de-DE")}</td>
        <td class="px-4 py-3 text-center">
          <input type="checkbox" id="beitrag-cb-${user.id}" ${beitragBezahlt ? "checked" : ""}
            onchange="toggleBeitrag('${user.id}', this.checked)"
            class="w-4 h-4 accent-[var(--color-primary)] cursor-pointer" />
        </td>
        <td class="px-4 py-3 whitespace-nowrap">
          <button onclick="startEditUser('${user.id}')" class="text-[var(--color-primary)] hover:opacity-80 text-sm font-medium mr-3">Bearbeiten</button>
          <button onclick="deleteUser('${user.id}')"
            class="text-red-500 hover:text-red-700 text-sm font-medium">Löschen</button>
        </td>
      </tr>`;
    }).join("");
  }

  loadUsers();

  // ── Terminverwaltung ──────────────────────────────────────────

  let termineCache: any[] = [];
  let editingTerminId: string | null = null;

  async function loadTermine() {
    const tbody = document.getElementById('termin-table-body');
    if (!tbody) return;

    let data: any[];
    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/termine?select=*&order=datum.asc`,
        { headers: headers() }
      );
      if (handleUnauthorized(res)) return;
      data = await res.json();
    } catch (e: any) {
      tbody.innerHTML = `<tr><td colspan="5" class="px-4 py-6 text-center text-red-500">Fehler: ${e.message}</td></tr>`;
      return;
    }

    termineCache = Array.isArray(data) ? data : [];

    if (!termineCache.length) {
      tbody.innerHTML = `<tr><td colspan="5" class="px-4 py-6 text-center text-gray-400">Keine Termine gefunden.</td></tr>`;
      return;
    }

    tbody.innerHTML = termineCache.map((t) => {
      const isEditing = editingTerminId === t.id;
      const safeTitel = escapeHtml(t.titel || '');
      const safeOrt   = escapeHtml(t.ort || '');
      const uhrzeit   = t.uhrzeit ? t.uhrzeit.slice(0, 5) : '';
      const datum     = t.datum ? new Date(t.datum + 'T00:00:00').toLocaleDateString('de-DE') : '—';

      if (isEditing) {
        return `
        <tr class="border-t border-gray-100 bg-gray-50/60">
          <td class="px-4 py-3">
            <input id="et-datum-${t.id}" type="date" value="${t.datum}"
              class="w-full border border-gray-300 rounded-md px-2 py-1 text-sm" />
          </td>
          <td class="px-4 py-3">
            <input id="et-titel-${t.id}" type="text" value="${safeTitel}"
              class="w-full border border-gray-300 rounded-md px-2 py-1 text-sm mb-2" />
            <div id="et-${t.id}-preview" class="flex flex-wrap gap-1 mb-1 min-h-[20px]"></div>
            <div class="flex gap-1">
              <input id="et-${t.id}-tag-text" type="text" placeholder="Badge Text"
                class="flex-1 border border-gray-300 rounded-md px-2 py-1 text-xs min-w-0" />
              <select id="et-${t.id}-tag-color"
                class="border border-gray-300 rounded-md px-1 py-1 text-xs">
                <option value="primary">Grün</option>
                <option value="dark">Dunkel</option>
                <option value="gray">Grau</option>
                <option value="blue">Blau</option>
                <option value="orange">Orange</option>
                <option value="red">Rot</option>
              </select>
              <button type="button" onclick="addTag('et-${t.id}')"
                class="bg-gray-100 hover:bg-gray-200 text-gray-600 px-2 py-1 rounded text-xs whitespace-nowrap">+ Badge</button>
            </div>
          </td>
          <td class="px-4 py-3">
            <input id="et-uhrzeit-${t.id}" type="time" value="${uhrzeit}"
              class="w-full border border-gray-300 rounded-md px-2 py-1 text-sm" />
          </td>
          <td class="px-4 py-3">
            <input id="et-ort-${t.id}" type="text" value="${safeOrt}"
              class="w-full border border-gray-300 rounded-md px-2 py-1 text-sm" />
          </td>
          <td class="px-4 py-3 whitespace-nowrap">
            <button onclick="saveTermin('${t.id}')" class="text-[var(--color-primary)] hover:opacity-80 text-sm font-medium mr-3">Speichern</button>
            <button onclick="cancelEditTermin()" class="text-gray-600 hover:text-gray-900 text-sm font-medium">Abbrechen</button>
          </td>
        </tr>`;
      }

      return `
      <tr class="border-t border-gray-100">
        <td class="px-4 py-3">${datum}</td>
        <td class="px-4 py-3">
          <span class="font-medium">${safeTitel}</span>
          ${tagsDisplayHtml(t.tags || [])}
        </td>
        <td class="px-4 py-3 text-gray-500">${uhrzeit ? uhrzeit + ' Uhr' : '—'}</td>
        <td class="px-4 py-3 text-gray-500">${safeOrt || '—'}</td>
        <td class="px-4 py-3 whitespace-nowrap">
          <button onclick="startEditTermin('${t.id}')" class="text-[var(--color-primary)] hover:opacity-80 text-sm font-medium mr-3">Bearbeiten</button>
          <button onclick="deleteTermin('${t.id}')" class="text-red-500 hover:text-red-700 text-sm font-medium">Löschen</button>
        </td>
      </tr>`;
    }).join('');
    if (editingTerminId) refreshTagEditor(`et-${editingTerminId}`);
  }

  async function deleteTermin(id: string) {
    const t = termineCache.find(x => x.id === id);
    if (!confirm(`Termin "${t?.titel || id}" wirklich löschen?`)) return;

    const res = await fetch(`${SUPABASE_URL}/rest/v1/termine?id=eq.${id}`, {
      method: 'DELETE',
      headers: headers(),
    });
    if (!res.ok) { showToast('Fehler beim Löschen: ' + res.status, 'error'); return; }
    loadTermine();
    showToast(`Termin "${t?.titel || ''}" wurde gelöscht`);
  }

  function startEditTermin(id: string) {
    const t = termineCache.find(x => x.id === id);
    tagsStore.set(`et-${id}`, JSON.parse(JSON.stringify(t?.tags || [])));
    editingTerminId = id;
    loadTermine();
  }

  function cancelEditTermin() {
    if (editingTerminId) tagsStore.delete(`et-${editingTerminId}`);
    editingTerminId = null;
    loadTermine();
  }

  async function saveTermin(id: string) {
    const titel    = (document.getElementById(`et-titel-${id}`) as HTMLInputElement)?.value.trim();
    const datum    = (document.getElementById(`et-datum-${id}`) as HTMLInputElement)?.value;
    const uhrzeit  = (document.getElementById(`et-uhrzeit-${id}`) as HTMLInputElement)?.value || null;
    const ort      = (document.getElementById(`et-ort-${id}`) as HTMLInputElement)?.value.trim() || null;

    if (!titel || !datum) { alert('Titel und Datum sind erforderlich.'); return; }

    const tags = tagsStore.get(`et-${id}`) || [];

    const res = await fetch(`${SUPABASE_URL}/rest/v1/termine?id=eq.${id}`, {
      method: 'PATCH',
      headers: { ...headers(), 'Prefer': 'return=minimal' },
      body: JSON.stringify({ titel, datum, uhrzeit, ort, tags }),
    });
    if (!res.ok) { showToast('Fehler beim Speichern: ' + res.status, 'error'); return; }

    tagsStore.delete(`et-${id}`);
    editingTerminId = null;
    loadTermine();
    showToast('Termin wurde gespeichert');
  }

  (window as any).deleteTermin      = deleteTermin;
  (window as any).startEditTermin   = startEditTermin;
  (window as any).cancelEditTermin  = cancelEditTermin;
  (window as any).saveTermin        = saveTermin;
  (window as any).addTag            = addTag;
  (window as any).removeTag         = removeTag;

  loadTermine();

  document.getElementById('create-termin-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const titel       = (document.getElementById('t-titel') as HTMLInputElement).value.trim();
    const datum       = (document.getElementById('t-datum') as HTMLInputElement).value;
    const uhrzeit     = (document.getElementById('t-uhrzeit') as HTMLInputElement).value || null;
    const ort         = (document.getElementById('t-ort') as HTMLInputElement).value.trim() || null;
    const beschreibung = (document.getElementById('t-beschreibung') as HTMLTextAreaElement).value.trim() || null;

    const errEl = document.getElementById('termin-error');
    const okEl  = document.getElementById('termin-success');
    errEl?.classList.add('hidden');
    okEl?.classList.add('hidden');

    if (!titel || !datum) {
      errEl!.textContent = 'Titel und Datum sind erforderlich.';
      errEl?.classList.remove('hidden');
      return;
    }

    const res = await fetch(`${SUPABASE_URL}/rest/v1/termine`, {
      method: 'POST',
      headers: { ...headers(), 'Prefer': 'return=minimal' },
      body: JSON.stringify({ titel, datum, uhrzeit, ort, beschreibung, tags: tagsStore.get('create-termin') || [] }),
    });

    if (!res.ok) {
      errEl!.textContent = 'Fehler beim Erstellen: ' + res.status;
      errEl?.classList.remove('hidden');
      return;
    }

    okEl!.textContent = `Termin "${titel}" wurde erstellt!`;
    okEl?.classList.remove('hidden');
    (e.target as HTMLFormElement).reset();
    tagsStore.set('create-termin', []);
    refreshTagEditor('create-termin');
    loadTermine();
    sendEmailNotification({ type: 'termin', titel, datum, uhrzeit, ort, beschreibung });
  });

  // ── Kontaktanfragen ──────────────────────────────────────────

  let anfragenCache: any[] = [];

  function betreffLabel(val: string) {
    const map: Record<string, string> = {
      mitgliedschaft: 'Mitgliedschaft',
      angelschein: 'Angelschein / Erlaubnis',
      veranstaltung: 'Veranstaltung',
      sonstiges: 'Sonstiges',
    };
    return map[val] || val || '—';
  }

  async function loadAnfragen() {
    const tbody = document.getElementById('anfragen-table-body');
    if (!tbody) return;

    let data: any[];
    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/kontakt_anfragen?select=*&order=created_at.desc`,
        { headers: headers() }
      );
      if (handleUnauthorized(res)) return;
      if (!res.ok) {
        const errText = await res.text();
        tbody.innerHTML = `<tr><td colspan="6" class="px-4 py-6 text-center text-red-500">Kontaktanfragen konnten nicht geladen werden (${res.status}). ${escapeHtml(errText || '')}</td></tr>`;
        return;
      }
      data = await res.json();
    } catch (e: any) {
      tbody.innerHTML = `<tr><td colspan="6" class="px-4 py-6 text-center text-red-500">Fehler: ${e.message}</td></tr>`;
      return;
    }

    anfragenCache = Array.isArray(data) ? data : [];

    const badge = document.getElementById('anfragen-badge');
    if (badge) {
      if (anfragenCache.length > 0) {
        badge.textContent = `${anfragenCache.length} Anfrage${anfragenCache.length !== 1 ? 'n' : ''}`;
        badge.classList.remove('hidden');
      } else {
        badge.classList.add('hidden');
      }
    }

    if (!anfragenCache.length) {
      tbody.innerHTML = `<tr><td colspan="6" class="px-4 py-6 text-center text-gray-400">Keine Anfragen vorhanden.</td></tr>`;
      return;
    }

    tbody.innerHTML = anfragenCache.map((a) => {
      const datum = a.created_at ? new Date(a.created_at).toLocaleDateString('de-DE') : '—';
      const name = escapeHtml(`${a.vorname || ''} ${a.nachname || ''}`.trim()) || '—';
      const email = escapeHtml(a.email || '—');
      const telefon = a.telefon ? escapeHtml(a.telefon) : null;
      const betreff = betreffLabel(a.betreff);
      const nachricht = escapeHtml(a.nachricht || '');
      const preview = nachricht.length > 50 ? nachricht.slice(0, 50) + '…' : nachricht;
      return `
      <tr class="border-t border-gray-100">
        <td class="px-4 py-3 text-gray-400 whitespace-nowrap">${datum}</td>
        <td class="px-4 py-3 font-medium">
          ${name}
          ${telefon ? `<p class="text-xs text-gray-400 font-normal">${telefon}</p>` : ''}
        </td>
        <td class="px-4 py-3">${email}</td>
        <td class="px-4 py-3">
          <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-[#d1e5e3] text-[var(--color-secondary)]">${betreff}</span>
        </td>
        <td class="px-4 py-3 text-gray-600 max-w-xs">
          ${preview}
          ${nachricht.length > 50 ? `<button onclick="openMsgModal('${a.id}')" class="ml-1 text-[var(--color-primary)] text-xs underline underline-offset-2 hover:opacity-80">mehr</button>` : ''}
        </td>
        <td class="px-4 py-3 whitespace-nowrap">
          <button onclick="openMsgModal('${a.id}')" class="text-[var(--color-primary)] hover:opacity-80 text-sm font-medium mr-3">Details</button>
          <button onclick="deleteAnfrage('${a.id}')" class="text-red-500 hover:text-red-700 text-sm font-medium">Löschen</button>
        </td>
      </tr>`;
    }).join('');
  }

  async function deleteAnfrage(id: string) {
    const a = anfragenCache.find(x => x.id === id);
    const label = a ? `${a.vorname || ''} ${a.nachname || ''}`.trim() || a.email : id;
    if (!confirm(`Anfrage von "${label}" wirklich löschen?`)) return;

    const res = await fetch(`${SUPABASE_URL}/rest/v1/kontakt_anfragen?id=eq.${id}`, {
      method: 'DELETE',
      headers: headers(),
    });
    if (!res.ok) { showToast('Fehler beim Löschen: ' + res.status, 'error'); return; }
    loadAnfragen();
    showToast(`Anfrage von "${label}" wurde gelöscht`);
  }

  function openMsgModal(id: string) {
    const a = anfragenCache.find(x => x.id === id);
    if (!a) return;
    const modal = document.getElementById('msg-modal');
    const metaEl = document.getElementById('modal-meta');
    const subjectEl = document.getElementById('modal-subject');
    const bodyEl = document.getElementById('modal-body');
    if (!modal || !metaEl || !subjectEl || !bodyEl) return;

    const name = `${a.vorname || ''} ${a.nachname || ''}`.trim() || a.email;
    const datum = a.created_at ? new Date(a.created_at).toLocaleString('de-DE') : '';
    metaEl.textContent = `${name} · ${a.email}${a.telefon ? ' · ' + a.telefon : ''} · ${datum}`;
    subjectEl.textContent = betreffLabel(a.betreff);
    bodyEl.textContent = a.nachricht || '';
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function closeMsgModal() {
    const modal = document.getElementById('msg-modal');
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
  }

  document.getElementById('msg-modal')?.addEventListener('click', (e) => {
    if (e.target === document.getElementById('msg-modal')) closeMsgModal();
  });

  (window as any).deleteAnfrage = deleteAnfrage;
  (window as any).openMsgModal  = openMsgModal;
  (window as any).closeMsgModal = closeMsgModal;

  loadAnfragen();

  // Neuen User erstellen
  document.getElementById("create-user-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const email = (document.getElementById("new-email") as HTMLInputElement).value;
    const password = (document.getElementById("new-password") as HTMLInputElement).value;
    const name = (document.getElementById("new-name") as HTMLInputElement).value;
    const username = (document.getElementById("new-username") as HTMLInputElement).value;
    const role = (document.getElementById("new-role") as HTMLSelectElement).value;
    const errorEl = document.getElementById("create-error");
    const successEl = document.getElementById("create-success");

    errorEl?.classList.add("hidden");
    successEl?.classList.add("hidden");

    if (!username) {
      errorEl?.classList.remove("hidden");
      errorEl!.textContent = "Benutzername ist erforderlich";
      return;
    }

    // User erstellen (raw fetch — ändert Admin-Session nicht)
    const signUpRes = await fetch(`${SUPABASE_URL}/auth/v1/signup`, {
      method: 'POST',
      headers: { 'apikey': SUPABASE_KEY, 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, password }),
    });
    const signUpData = await signUpRes.json();

    if (!signUpRes.ok || signUpData.error) {
      errorEl?.classList.remove("hidden");
      errorEl!.textContent = signUpData.error?.message || signUpData.msg || 'Fehler beim Erstellen';
      return;
    }

    const newUserId = signUpData.user?.id;

    // Profil erstellen/aktualisieren via RPC (SECURITY DEFINER → bypasses RLS)
    const rpcRes = await fetch(`${SUPABASE_URL}/rest/v1/rpc/create_or_update_profile`, {
      method: 'POST',
      headers: headers(),
      body: JSON.stringify({
        target_id: newUserId,
        target_email: email,
        target_name: name,
        target_username: username,
        target_role: role,
      }),
    });

    if (!rpcRes.ok) {
      const rpcErrorText = await rpcRes.text();
      errorEl?.classList.remove("hidden");
      errorEl!.textContent = `Profil konnte nicht erstellt werden: ${rpcErrorText || rpcRes.status}`;
      return;
    }

    successEl?.classList.remove("hidden");
    successEl!.textContent = `Mitglied "${name}" wurde erstellt!`;
    (e.target as HTMLFormElement).reset();
    loadUsers();
    showToast(`Mitglied "${name}" wurde erstellt`);
  });
</script>
