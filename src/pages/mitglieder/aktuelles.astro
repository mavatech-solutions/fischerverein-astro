---
import ProtectedLayout from "../../layouts/ProtectedLayout.astro";
---

<ProtectedLayout title="Aktuelles">
  <!-- Hero -->
  <section class="bg-[var(--color-secondary)] text-white">
    <div class="h-[180px]"></div>
    <div class="container mx-auto px-4 pb-16">
      <p class="text-sm font-medium uppercase tracking-widest text-white/60 mb-2">Mitgliederbereich</p>
      <h1 class="text-4xl font-bold mb-2">Aktuelles</h1>
      <p class="text-white/70 text-lg">Neuigkeiten, Berichte und Informationen aus dem Vereinsleben.</p>
    </div>
  </section>

  <section class="bg-[var(--color-bg-light)] py-16 min-h-[60vh]">
    <div class="container mx-auto px-4">

      <!-- Laden -->
      <div id="feed-loading" class="text-center py-16">
        <div class="inline-block w-8 h-8 border-4 border-[var(--color-primary)] border-t-transparent rounded-full animate-spin"></div>
        <p class="mt-3 text-gray-500">Lade Beiträge...</p>
      </div>

      <!-- Feed -->
      <div id="feed-list" class="hidden space-y-5"></div>

      <!-- Pagination -->
      <div id="pagination" class="hidden mt-8 flex items-center justify-center gap-2"></div>

      <!-- Leer -->
      <div id="feed-empty" class="hidden text-center py-20">
        <div class="text-5xl mb-4">📰</div>
        <p class="text-gray-500 text-lg font-medium">Noch keine Beiträge vorhanden.</p>
        <p class="text-gray-400 text-sm mt-1">Schau später nochmal vorbei.</p>
      </div>

      <!-- Fehler -->
      <div id="feed-error" class="hidden text-center py-20">
        <div class="text-5xl mb-4">⚠️</div>
        <p class="text-red-500 font-medium">Beiträge konnten nicht geladen werden.</p>
        <button onclick="location.reload()" class="mt-3 text-sm text-[var(--color-primary)] underline">Seite neu laden</button>
      </div>

    </div>
  </section>
</ProtectedLayout>

<script>
  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  function getJwt() {
    const key = Object.keys(localStorage).find(k => k.includes('auth-token'));
    const stored = key ? JSON.parse(localStorage.getItem(key) || '{}') : {};
    return stored?.access_token || SUPABASE_KEY;
  }

  function esc(s: string) {
    return String(s)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;');
  }

  function formatDate(dateStr: string) {
    return new Date(dateStr).toLocaleDateString('de-DE', {
      day: '2-digit', month: 'long', year: 'numeric',
      hour: '2-digit', minute: '2-digit',
    });
  }

  function relativeTime(dateStr: string) {
    const diff = Date.now() - new Date(dateStr).getTime();
    const mins = Math.floor(diff / 60000);
    if (mins < 1) return 'Gerade eben';
    if (mins < 60) return `vor ${mins} Minute${mins !== 1 ? 'n' : ''}`;
    const hours = Math.floor(mins / 60);
    if (hours < 24) return `vor ${hours} Stunde${hours !== 1 ? 'n' : ''}`;
    const days = Math.floor(hours / 24);
    if (days === 1) return 'Gestern';
    if (days < 7) return `vor ${days} Tagen`;
    return new Date(dateStr).toLocaleDateString('de-DE', { day: '2-digit', month: 'long', year: 'numeric' });
  }

  function formatSize(bytes: number | null) {
    if (!bytes) return '';
    if (bytes < 1024) return `${bytes} B`;
    if (bytes < 1048576) return `${(bytes / 1024).toFixed(0)} KB`;
    return `${(bytes / 1048576).toFixed(1)} MB`;
  }

  function initials(name: string) {
    return (name || 'U').split(' ').map((n: string) => n[0] || '').join('').toUpperCase().slice(0, 2) || 'U';
  }

  function fileIcon(mime: string | null) {
    if (!mime) return 'fa-file';
    if (mime.includes('pdf')) return 'fa-file-pdf';
    if (mime.includes('image')) return 'fa-file-image';
    if (mime.includes('word') || mime.includes('document')) return 'fa-file-word';
    if (mime.includes('sheet') || mime.includes('excel')) return 'fa-file-excel';
    if (mime.includes('powerpoint') || mime.includes('presentation')) return 'fa-file-powerpoint';
    if (mime.includes('zip') || mime.includes('rar') || mime.includes('archive')) return 'fa-file-zipper';
    return 'fa-file';
  }

  async function downloadAnhang(pfad: string, dateiname: string) {
    // Fenster sofort öffnen (während User-Geste) – iOS Safari blockiert sonst async window.open
    const win = window.open('', '_blank');
    try {
      const encodedPfad = pfad.split('/').map((s: string) => encodeURIComponent(s)).join('/');
      const res = await fetch(
        `${SUPABASE_URL}/storage/v1/object/sign/aktuelles/${encodedPfad}`,
        {
          method: 'POST',
          headers: {
            apikey: SUPABASE_KEY,
            Authorization: `Bearer ${getJwt()}`,
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ expiresIn: 300 }),
        }
      );
      const { signedURL } = await res.json();
      if (win) win.location.href = `${SUPABASE_URL}/storage/v1${signedURL}`;
    } catch {
      win?.close();
      alert('Download fehlgeschlagen. Bitte Seite neu laden und erneut versuchen.');
    }
  }

  function postCard(post: any, anhaenge: any[]) {
    const sz = formatSize(0);
    const anhaengeHtml = anhaenge.length
      ? `<div class="pt-4 mt-4 border-t border-gray-100">
          <p class="text-xs font-semibold uppercase tracking-wide text-gray-400 mb-2.5">
            <i class="fa-solid fa-paperclip mr-1"></i>Anhänge
          </p>
          <div class="flex flex-wrap gap-2">
            ${anhaenge.map(a => {
              const size = formatSize(a.groesse);
              return `<button
                onclick="downloadAnhang('${esc(a.pfad)}','${esc(a.dateiname)}')"
                class="inline-flex items-center gap-2 text-sm bg-gray-50 hover:bg-[#d1e5e3] text-gray-700 hover:text-[var(--color-secondary)] border border-gray-200 hover:border-[var(--color-primary)] rounded-xl px-3 py-2 transition-all group">
                <i class="fa-solid ${fileIcon(a.mime_typ)} text-[var(--color-primary)]"></i>
                <span class="max-w-[180px] truncate">${esc(a.dateiname)}</span>
                ${size ? `<span class="text-gray-400 text-xs shrink-0">${size}</span>` : ''}
                <i class="fa-solid fa-download text-xs text-gray-400 group-hover:text-[var(--color-primary)] transition-colors shrink-0"></i>
              </button>`;
            }).join('')}
          </div>
        </div>`
      : '';

    return `
      <article class="bg-white rounded-2xl shadow-sm border ${post.pinned ? 'border-[var(--color-primary)]' : 'border-gray-100'} overflow-hidden transition-shadow hover:shadow-md">
        ${post.pinned ? '<div class="h-1 bg-[var(--color-primary)]"></div>' : ''}
        <div class="p-6">
          <!-- Autor + Datum + Pin -->
          <div class="flex items-start justify-between gap-3 mb-4">
            <div class="flex items-center gap-3 min-w-0">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-[#d1e5e3] text-[var(--color-secondary)] text-xs font-bold select-none">
                ${esc(initials(post.autor_name))}
              </div>
              <div class="min-w-0">
                <p class="text-sm font-semibold text-[var(--color-dark)] truncate">${esc(post.autor_name || 'Unbekannt')}</p>
                <p class="text-xs text-gray-400" title="${esc(formatDate(post.created_at))}">${relativeTime(post.created_at)}</p>
              </div>
            </div>
            ${post.pinned
              ? `<span class="inline-flex items-center gap-1 shrink-0 text-xs font-semibold text-[var(--color-secondary)] bg-[#d1e5e3] px-2.5 py-1 rounded-full">
                  <i class="fa-solid fa-thumbtack text-[10px]"></i> Angepinnt
                </span>`
              : ''}
          </div>

          <!-- Titel -->
          <h2 class="text-xl font-bold text-[var(--color-dark)] mb-3 leading-tight">${esc(post.titel)}</h2>

          <!-- Inhalt -->
          <div class="text-gray-600 text-md leading-relaxed whitespace-pre-line">${esc(post.inhalt)}</div>

          <!-- Anhänge -->
          ${anhaengeHtml}
        </div>
      </article>`;
  }

  const PER_PAGE = 10;
  let allPosts: any[] = [];
  let byPost = new Map<string, any[]>();
  let currentPage = 1;

  function totalPages() {
    return Math.ceil(allPosts.length / PER_PAGE);
  }

  function renderPage() {
    const elList = document.getElementById('feed-list');
    if (!elList) return;

    const start = (currentPage - 1) * PER_PAGE;
    const pagePosts = allPosts.slice(start, start + PER_PAGE);

    elList.innerHTML = pagePosts.map((p: any) => postCard(p, byPost.get(p.id) || [])).join('');
    elList.classList.remove('hidden');
    renderPagination();
  }

  function renderPagination() {
    const el = document.getElementById('pagination');
    if (!el) return;
    const total = totalPages();

    if (total <= 1) { el.classList.add('hidden'); return; }
    el.classList.remove('hidden');

    const btnBase = 'flex h-9 w-9 items-center justify-center rounded-lg text-sm font-medium transition';
    const btnActive = 'bg-[var(--color-primary)] text-white shadow-sm';
    const btnIdle = 'bg-white border border-gray-200 text-gray-600 hover:border-[var(--color-primary)] hover:text-[var(--color-primary)]';
    const btnDisabled = 'bg-white border border-gray-100 text-gray-300 cursor-not-allowed';

    const pageButtons = Array.from({ length: total }, (_, i) => i + 1).map(p => `
      <button onclick="goToPage(${p})" class="${btnBase} ${p === currentPage ? btnActive : btnIdle}">
        ${p}
      </button>`).join('');

    el.innerHTML = `
      <button onclick="goToPage(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''}
        class="${btnBase} ${currentPage === 1 ? btnDisabled : btnIdle} px-3 w-auto gap-1">
        <i class="fa-solid fa-chevron-left text-xs"></i>
      </button>
      ${pageButtons}
      <button onclick="goToPage(${currentPage + 1})" ${currentPage === total ? 'disabled' : ''}
        class="${btnBase} ${currentPage === total ? btnDisabled : btnIdle} px-3 w-auto gap-1">
        <i class="fa-solid fa-chevron-right text-xs"></i>
      </button>`;
  }

  function goToPage(page: number) {
    if (page < 1 || page > totalPages()) return;
    currentPage = page;
    renderPage();
    document.getElementById('feed-list')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  async function loadFeed() {
    const elLoading = document.getElementById('feed-loading');
    const elEmpty   = document.getElementById('feed-empty');
    const elError   = document.getElementById('feed-error');

    try {
      const h = { apikey: SUPABASE_KEY, Authorization: `Bearer ${getJwt()}` };
      const [postsRes, anhaengeRes] = await Promise.all([
        fetch(`${SUPABASE_URL}/rest/v1/aktuelles?select=*&order=pinned.desc,created_at.desc`, { headers: h }),
        fetch(`${SUPABASE_URL}/rest/v1/aktuelles_anhaenge?select=*`, { headers: h }),
      ]);

      if (!postsRes.ok) throw new Error('HTTP ' + postsRes.status);

      const posts   = await postsRes.json();
      const anhaenge = anhaengeRes.ok ? await anhaengeRes.json() : [];

      elLoading?.classList.add('hidden');

      if (!posts?.length) {
        elEmpty?.classList.remove('hidden');
        return;
      }

      byPost = new Map();
      for (const a of anhaenge) {
        if (!byPost.has(a.post_id)) byPost.set(a.post_id, []);
        byPost.get(a.post_id)!.push(a);
      }

      allPosts = posts;
      currentPage = 1;
      renderPage();
    } catch {
      elLoading?.classList.add('hidden');
      elError?.classList.remove('hidden');
    }
  }

  (window as any).downloadAnhang = downloadAnhang;
  (window as any).goToPage = goToPage;
  loadFeed();
</script>
