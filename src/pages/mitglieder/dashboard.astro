---
import ProtectedLayout from '../../layouts/ProtectedLayout.astro';
---

<ProtectedLayout title="Dashboard">
  <!-- Hero -->
  <section class="bg-[var(--color-secondary)] text-white">
    <div class="h-[120px]"></div>
    <div class="container mx-auto px-4">
      <p class="text-sm font-medium uppercase tracking-widest text-white/60 mb-2">Mitgliederbereich</p>
      <h1 class="text-4xl font-bold mb-2" id="dash-greeting">Willkommen!</h1>
      <p class="text-white/70 text-lg">Schön, dass du dabei bist.</p>
    </div>
    <div class="h-[120px]"></div>
  </section>

  <section class="bg-[var(--color-bg-light)] py-16">
    <div class="container mx-auto px-4">

      <!-- Schnellzugriff-Karten -->
      <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-5">Schnellzugriff</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-12">

        <a href="/mitglieder/profil"
           class="group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md hover:border-[var(--color-primary)] transition-all p-6 flex items-start gap-4">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-[#d1e5e3] text-[var(--color-secondary)] group-hover:bg-[var(--color-primary)] group-hover:text-white transition-colors">
            <i class="fa-solid fa-user text-base"></i>
          </div>
          <div>
            <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-0.5">Konto</p>
            <p class="text-base font-semibold text-[var(--color-dark)]">Mein Profil</p>
            <p class="text-sm text-gray-500 mt-1">Daten ansehen &amp; anpassen</p>
          </div>
        </a>

        <a href="/mitglieder/termine"
           class="group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md hover:border-[var(--color-primary)] transition-all p-6 flex items-start gap-4">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-[#d1e5e3] text-[var(--color-secondary)] group-hover:bg-[var(--color-primary)] group-hover:text-white transition-colors">
            <i class="fa-solid fa-calendar-days text-base"></i>
          </div>
          <div>
            <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-0.5">Verein</p>
            <p class="text-base font-semibold text-[var(--color-dark)]">Termine</p>
            <p class="text-sm text-gray-500 mt-1">Anstehende Veranstaltungen</p>
          </div>
        </a>

        <a href="/mitglieder/aktuelles"
           class="group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md hover:border-[var(--color-primary)] transition-all p-6 flex items-start gap-4">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-[#d1e5e3] text-[var(--color-secondary)] group-hover:bg-[var(--color-primary)] group-hover:text-white transition-colors">
            <i class="fa-solid fa-newspaper text-base"></i>
          </div>
          <div>
            <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-0.5">Verein</p>
            <p class="text-base font-semibold text-[var(--color-dark)]">Aktuelles</p>
            <p class="text-sm text-gray-500 mt-1">Neuigkeiten &amp; Berichte</p>
          </div>
        </a>

        <a href="/mitglieder/dokumente"
           class="group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md hover:border-[var(--color-primary)] transition-all p-6 flex items-start gap-4">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-[#d1e5e3] text-[var(--color-secondary)] group-hover:bg-[var(--color-primary)] group-hover:text-white transition-colors">
            <i class="fa-solid fa-folder-open text-base"></i>
          </div>
          <div>
            <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-0.5">Verein</p>
            <p class="text-base font-semibold text-[var(--color-dark)]">Downloads</p>
            <p class="text-sm text-gray-500 mt-1">Dokumente &amp; Formulare</p>
          </div>
        </a>

        <a href="/mitglieder/faenge"
           class="group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md hover:border-[var(--color-primary)] transition-all p-6 flex items-start gap-4">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-[#d1e5e3] text-[var(--color-secondary)] group-hover:bg-[var(--color-primary)] group-hover:text-white transition-colors">
            <i class="fa-solid fa-trophy text-base"></i>
          </div>
          <div>
            <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-0.5">Wettbewerb</p>
            <p class="text-base font-semibold text-[var(--color-dark)]">Fangbuch &amp; Ranking</p>
            <p class="text-sm text-gray-500 mt-1">Fänge eintragen &amp; vergleichen</p>
          </div>
        </a>

        <a id="admin-link" href="/mitglieder/admin" style="display:none"
           class="group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md hover:border-[var(--color-primary)] transition-all p-6 flex items-start gap-4">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-[#d1e5e3] text-[var(--color-secondary)] group-hover:bg-[var(--color-primary)] group-hover:text-white transition-colors">
            <i class="fa-solid fa-shield-halved text-base"></i>
          </div>
          <div>
            <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-0.5">Administration</p>
            <p class="text-base font-semibold text-[var(--color-dark)]">Admin Panel</p>
            <p class="text-sm text-gray-500 mt-1">Mitglieder, Termine &amp; Anfragen</p>
          </div>
        </a>

        <a id="galerie-admin-link" href="/mitglieder/galerie-admin" style="display:none"
           class="group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md hover:border-[var(--color-primary)] transition-all p-6 flex items-start gap-4">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-[#d1e5e3] text-[var(--color-secondary)] group-hover:bg-[var(--color-primary)] group-hover:text-white transition-colors">
            <i class="fa-solid fa-images text-base"></i>
          </div>
          <div>
            <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-0.5">Inhalt</p>
            <p class="text-base font-semibold text-[var(--color-dark)]">Galerie verwalten</p>
            <p class="text-sm text-gray-500 mt-1">Bilder hinzufügen &amp; löschen</p>
          </div>
        </a>

        <a id="termine-admin-link" href="/mitglieder/termine-admin" style="display:none"
           class="group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md hover:border-[var(--color-primary)] transition-all p-6 flex items-start gap-4">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-[#d1e5e3] text-[var(--color-secondary)] group-hover:bg-[var(--color-primary)] group-hover:text-white transition-colors">
            <i class="fa-solid fa-calendar-plus text-base"></i>
          </div>
          <div>
            <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-0.5">Inhalt</p>
            <p class="text-base font-semibold text-[var(--color-dark)]">Termine verwalten</p>
            <p class="text-sm text-gray-500 mt-1">Termine hinzufügen &amp; bearbeiten</p>
          </div>
        </a>

        <a id="aktuelles-admin-link" href="/mitglieder/aktuelles-admin" style="display:none"
           class="group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md hover:border-[var(--color-primary)] transition-all p-6 flex items-start gap-4">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-[#d1e5e3] text-[var(--color-secondary)] group-hover:bg-[var(--color-primary)] group-hover:text-white transition-colors">
            <i class="fa-solid fa-pen-to-square text-base"></i>
          </div>
          <div>
            <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-0.5">Inhalt</p>
            <p class="text-base font-semibold text-[var(--color-dark)]">Aktuelles verwalten</p>
            <p class="text-sm text-gray-500 mt-1">Beiträge &amp; Anhänge</p>
          </div>
        </a>

        <a id="dokumente-admin-link" href="/mitglieder/dokumente-admin" style="display:none"
           class="group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md hover:border-[var(--color-primary)] transition-all p-6 flex items-start gap-4">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-[#d1e5e3] text-[var(--color-secondary)] group-hover:bg-[var(--color-primary)] group-hover:text-white transition-colors">
            <i class="fa-solid fa-file-arrow-up text-base"></i>
          </div>
          <div>
            <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-0.5">Inhalt</p>
            <p class="text-base font-semibold text-[var(--color-dark)]">Dokumente verwalten</p>
            <p class="text-sm text-gray-500 mt-1">Vereinsdokumente &amp; Formulare</p>
          </div>
        </a>

        <a id="faenge-admin-link" href="/mitglieder/faenge-admin" style="display:none"
           class="group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md hover:border-[var(--color-primary)] transition-all p-6 flex items-start gap-4">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-[#d1e5e3] text-[var(--color-secondary)] group-hover:bg-[var(--color-primary)] group-hover:text-white transition-colors">
            <i class="fa-solid fa-fish text-base"></i>
          </div>
          <div>
            <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-0.5">Inhalt</p>
            <p class="text-base font-semibold text-[var(--color-dark)]">Fänge verwalten</p>
            <p class="text-sm text-gray-500 mt-1">Einträge prüfen &amp; löschen</p>
          </div>
        </a>

      </div>

      <!-- Jahresbeitrag -->
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 mb-5">
        <p class="text-sm font-semibold text-[var(--color-dark)] mb-4">Jahresbeitrag</p>
        <div id="beitrag-content"><p class="text-sm text-gray-400">Lädt…</p></div>
      </div>

      <!-- Nächster Termin -->
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
          <p class="text-sm font-semibold text-[var(--color-dark)]">Nächster Termin</p>
          <a href="/mitglieder/termine" class="inline-flex items-center gap-1 text-xs font-semibold text-[var(--color-primary)] bg-[#d1e5e3] px-3 py-1.5 rounded-full hover:bg-[var(--color-primary)] hover:text-white transition-colors">Alle anzeigen <i class="fa-solid fa-arrow-right text-[10px]"></i></a>
        </div>
        <div id="next-termin" class="text-sm text-gray-400">Lädt…</div>
      </div>

    </div>
  </section>
</ProtectedLayout>

<script>
  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  // Links je nach Rolle einblenden
  const cookieRole = document.cookie.match(/sb-role=([^;]+)/)?.[1];
  if (cookieRole === 'admin') {
    document.getElementById('admin-link')?.style.setProperty('display', 'flex');
  }
  if (cookieRole === 'admin' || cookieRole === 'moderator') {
    document.getElementById('galerie-admin-link')?.style.setProperty('display', 'flex');
    document.getElementById('termine-admin-link')?.style.setProperty('display', 'flex');
    document.getElementById('aktuelles-admin-link')?.style.setProperty('display', 'flex');
    document.getElementById('dokumente-admin-link')?.style.setProperty('display', 'flex');
    document.getElementById('faenge-admin-link')?.style.setProperty('display', 'flex');
  }

  // Begrüßung mit Name
  function getJwt() {
    const key = Object.keys(localStorage).find(k => k.includes('auth-token'));
    const stored = key ? JSON.parse(localStorage.getItem(key) || '{}') : {};
    return stored?.access_token || null;
  }

  async function loadGreeting() {
    const jwt = getJwt();
    if (!jwt || !SUPABASE_URL) return;
    const payload = JSON.parse(atob(jwt.split('.')[1]));
    const userId = payload?.sub;
    if (!userId) return;

    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/profiles?id=eq.${userId}&select=full_name,beitrag_bezahlt_jahr`,
        { headers: { apikey: SUPABASE_KEY, Authorization: `Bearer ${jwt}` } }
      );
      const data = await res.json();
      const profile = data?.[0];
      const name = profile?.full_name?.split(' ')[0];
      if (name) {
        const el = document.getElementById('dash-greeting');
        if (el) el.textContent = `Willkommen, ${name}!`;
      }
      renderBeitragSection(profile?.full_name, profile?.beitrag_bezahlt_jahr ?? null);
    } catch { renderBeitragSection(undefined, null); }
  }

  function renderBeitragSection(fullName: string | undefined, beitragJahr: number | null) {
    const el = document.getElementById('beitrag-content');
    if (!el) return;
    const currentYear = new Date().getFullYear();

    if (beitragJahr === currentYear) {
      el.innerHTML = `
        <div class="flex items-center gap-3">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-green-100 text-green-600">
            <i class="fa-solid fa-check text-sm"></i>
          </div>
          <div>
            <p class="font-semibold text-[var(--color-dark)]">Jahresbeitrag ${currentYear} bezahlt</p>
            <p class="text-gray-400 text-xs mt-0.5">Vielen Dank!</p>
          </div>
        </div>`;
      return;
    }

    const verwendung = fullName ? `Jahresbeitrag ${currentYear} ${fullName}` : `Jahresbeitrag ${currentYear}`;
    el.innerHTML = `
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3">Per PayPal</p>
          <a href="https://www.paypal.me/IHRE-PAYPAL-ID" target="_blank" rel="noopener"
             class="inline-flex items-center gap-2 bg-[#0070BA] hover:bg-[#005ea6] text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition">
            <i class="fa-brands fa-paypal"></i>
            Mit PayPal bezahlen
          </a>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3">Per Banküberweisung</p>
          <dl class="text-sm space-y-1.5">
            <div class="flex gap-2"><dt class="text-gray-400 w-28 shrink-0">Kontoinhaber</dt><dd class="font-medium text-[var(--color-dark)]">Fischerverein Bottwartal Oberstenfeld-Gronau E.V.</dd></div>
            <div class="flex gap-2"><dt class="text-gray-400 w-28 shrink-0">IBAN</dt><dd class="font-mono text-[var(--color-dark)]">DE89 6029 1120 0328 4910 04</dd></div>
            <div class="flex gap-2"><dt class="text-gray-400 w-28 shrink-0">BIC</dt><dd class="font-mono text-[var(--color-dark)]">GENODES1VBK</dd></div>
            <div class="flex gap-2"><dt class="text-gray-400 w-28 shrink-0">Verwendung</dt><dd class="text-[var(--color-dark)]">${verwendung}</dd></div>
          </dl>
        </div>
      </div>`;
  }

  // Nächster Termin
  async function loadNextTermin() {
    const el = document.getElementById('next-termin');
    if (!el || !SUPABASE_URL) return;
    const today = new Date().toISOString().slice(0, 10);
    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/termine?datum=gte.${today}&order=datum.asc&limit=1&select=titel,datum,uhrzeit,ort`,
        { headers: { apikey: SUPABASE_KEY, Authorization: `Bearer ${getJwt() || SUPABASE_KEY}` } }
      );
      const data = await res.json();
      if (!Array.isArray(data) || !data.length) {
        el.textContent = 'Keine bevorstehenden Termine.';
        return;
      }
      const t = data[0];
      const datum = new Date(t.datum + 'T00:00:00').toLocaleDateString('de-DE', { weekday: 'long', day: '2-digit', month: 'long', year: 'numeric' });
      const uhrzeit = t.uhrzeit ? ' · ' + t.uhrzeit.slice(0, 5) + ' Uhr' : '';
      const ort = t.ort ? ' · ' + t.ort : '';
      el.innerHTML = `
        <div class="flex items-center gap-3">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-[#d1e5e3] text-[var(--color-secondary)]">
            <i class="fa-solid fa-calendar-check text-sm"></i>
          </div>
          <div>
            <p class="font-semibold text-[var(--color-dark)]">${t.titel}</p>
            <p class="text-gray-400 text-xs mt-0.5">${datum}${uhrzeit}${ort}</p>
          </div>
        </div>`;
    } catch { el.textContent = 'Termine konnten nicht geladen werden.'; }
  }

  loadGreeting();
  loadNextTermin();

  const loginFlag = sessionStorage.getItem('justLoggedIn');
  if (loginFlag) {
    sessionStorage.removeItem('justLoggedIn');
    const name = loginFlag !== '1' ? loginFlag : '';
    const div = document.createElement('div');
    div.style.cssText = [
      'position:fixed;bottom:24px;right:24px;z-index:9999',
      'padding:13px 20px;border-radius:12px',
      'background:#16a34a;color:#fff',
      'font-size:14px;font-weight:500;font-family:inherit',
      'display:flex;align-items:center;gap:10px',
      'box-shadow:0 4px 20px rgba(0,0,0,.18)',
      'transform:translateY(10px);opacity:0',
      'transition:opacity .25s ease,transform .25s ease',
      'max-width:360px;line-height:1.4',
    ].join(';');
    div.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5-4-4 1.41-1.41L10 13.67l6.59-6.59L18 8.5l-8 8z"/></svg><span>${name ? `Willkommen zurück, ${name}!` : 'Erfolgreich angemeldet!'}</span>`;
    document.body.appendChild(div);
    requestAnimationFrame(() => requestAnimationFrame(() => {
      div.style.opacity = '1';
      div.style.transform = 'translateY(0)';
    }));
    setTimeout(() => {
      div.style.opacity = '0';
      div.style.transform = 'translateY(10px)';
      setTimeout(() => div.remove(), 300);
    }, 4500);
  }
</script>