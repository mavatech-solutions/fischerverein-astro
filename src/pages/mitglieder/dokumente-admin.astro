---
import ModeratorLayout from '../../layouts/ModeratorLayout.astro';
---

<ModeratorLayout title="Dokumente verwalten">
  <div class="container mx-auto px-4 py-12">
    <p class="mb-2 text-3xl font-semibold">Dokumente verwalten</p>
    <p class="text-gray-500 mb-10">Vereinsdokumente hochladen und löschen</p>

    <!-- Dokument hochladen -->
    <div class="bg-white shadow rounded-xl p-6 mb-10">
      <h2 class="h3 mb-6">Dokument hochladen</h2>

      <form id="add-dok-form" class="grid grid-cols-12 gap-4">
        <div class="col-span-12 md:col-span-5">
          <label class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
          <input id="dok-name" type="text" placeholder="Satzung 2024"
            class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-[var(--color-primary)]" />
        </div>
        <div class="col-span-12 md:col-span-4">
          <label class="block text-sm font-medium text-gray-700 mb-1">Kategorie</label>
          <input id="dok-kategorie" type="text" placeholder="z.B. Satzung & Ordnungen"
            class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-[var(--color-primary)]" />
        </div>
        <div class="col-span-12 md:col-span-3">
          <label class="block text-sm font-medium text-gray-700 mb-1">Beschreibung (optional)</label>
          <input id="dok-beschreibung" type="text" placeholder="Kurze Erklärung"
            class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-[var(--color-primary)]" />
        </div>

        <!-- Datei-Upload -->
        <div class="col-span-12">
          <label class="block text-sm font-medium text-gray-700 mb-1">Datei *</label>
          <label id="drop-zone"
            class="flex flex-col items-center justify-center w-full h-36 border-2 border-dashed border-gray-300 rounded-xl cursor-pointer bg-gray-50 hover:bg-gray-100 hover:border-[var(--color-primary)] transition-colors">
            <div id="drop-label" class="flex flex-col items-center gap-2 pointer-events-none">
              <i class="fa-solid fa-cloud-arrow-up text-3xl text-gray-300"></i>
              <p class="text-sm text-gray-500">Datei hier ablegen oder <span class="text-[var(--color-primary)] font-medium">auswählen</span></p>
              <p class="text-xs text-gray-400">PDF, Word, Excel, ZIP — max. 20 MB</p>
            </div>
            <input id="dok-file" type="file" class="hidden"
              accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.zip,.rar,.txt,.csv" />
          </label>
        </div>

        <!-- Upload-Fortschritt -->
        <div id="progress-wrap" class="col-span-12 hidden">
          <div class="flex items-center gap-3">
            <div class="flex-1 bg-gray-100 rounded-full h-2 overflow-hidden">
              <div id="progress-bar" class="h-2 bg-[var(--color-primary)] rounded-full transition-all duration-300" style="width:0%"></div>
            </div>
            <span id="progress-text" class="text-xs text-gray-500 w-10 text-right">0%</span>
          </div>
        </div>

        <div class="col-span-12 flex flex-wrap items-center gap-4">
          <button type="submit" id="submit-btn"
            class="bg-[var(--color-primary)] text-white px-6 py-2 rounded-md font-semibold hover:opacity-90 transition disabled:opacity-50 disabled:cursor-not-allowed">
            Hochladen
          </button>
          <p id="dok-error" class="text-red-500 text-sm hidden"></p>
          <p id="dok-success" class="text-green-600 text-sm hidden"></p>
        </div>
      </form>
    </div>

    <!-- Alle Dokumente -->
    <div class="bg-white shadow rounded-xl p-6">
      <h2 class="h3 mb-6">Alle Dokumente</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
          <thead class="bg-gray-100 text-gray-600">
            <tr>
              <th class="px-4 py-3 rounded-l-lg">Name</th>
              <th class="px-4 py-3">Kategorie</th>
              <th class="px-4 py-3">Beschreibung</th>
              <th class="px-4 py-3">Datei</th>
              <th class="px-4 py-3 rounded-r-lg">Aktionen</th>
            </tr>
          </thead>
          <tbody id="dok-table-body">
            <tr><td colspan="5" class="px-4 py-6 text-center text-gray-400">Lädt...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</ModeratorLayout>

<script>
  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  const BUCKET = 'dokumente';

  function showToast(msg: string, type: 'success' | 'error' = 'success') {
    const isError = type === 'error';
    const div = document.createElement('div');
    div.style.cssText = [
      'position:fixed;bottom:24px;right:24px;z-index:9999',
      'padding:13px 20px;border-radius:12px',
      `background:${isError ? '#dc2626' : '#16a34a'};color:#fff`,
      'font-size:14px;font-weight:500;font-family:inherit',
      'display:flex;align-items:center;gap:10px',
      'box-shadow:0 4px 20px rgba(0,0,0,.18)',
      'transform:translateY(10px);opacity:0',
      'transition:opacity .25s ease,transform .25s ease',
      'max-width:360px;line-height:1.4',
    ].join(';');
    div.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0">${
      isError
        ? '<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>'
        : '<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5-4-4 1.41-1.41L10 13.67l6.59-6.59L18 8.5l-8 8z"/>'
    }</svg><span>${msg}</span>`;
    document.body.appendChild(div);
    requestAnimationFrame(() => requestAnimationFrame(() => {
      div.style.opacity = '1'; div.style.transform = 'translateY(0)';
    }));
    setTimeout(() => {
      div.style.opacity = '0'; div.style.transform = 'translateY(10px)';
      setTimeout(() => div.remove(), 300);
    }, 4500);
  }

  function getJwt() {
    const key = Object.keys(localStorage).find(k => k.includes('auth-token'));
    const stored = key ? JSON.parse(localStorage.getItem(key) || '{}') : {};
    return stored?.access_token || SUPABASE_KEY;
  }

  function headers(contentType = 'application/json') {
    return { apikey: SUPABASE_KEY, Authorization: `Bearer ${getJwt()}`, 'Content-Type': contentType };
  }

  function escapeHtml(s: string) {
    return String(s || '')
      .replaceAll('&', '&amp;').replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;').replaceAll('"', '&quot;');
  }

  function slugify(name: string) {
    return name.toLowerCase().replace(/[^a-z0-9.\-_]/g, '_').replace(/_+/g, '_');
  }

  // Drag-and-drop + Dateiname anzeigen
  const fileInput = document.getElementById('dok-file') as HTMLInputElement;
  const dropZone  = document.getElementById('drop-zone') as HTMLLabelElement;
  const dropLabel = document.getElementById('drop-label')!;

  function showFileName(name: string) {
    dropLabel.innerHTML = `
      <i class="fa-solid fa-file-circle-check text-3xl text-[var(--color-primary)]"></i>
      <p class="text-sm font-medium text-[var(--color-dark)]">${escapeHtml(name)}</p>
      <p class="text-xs text-gray-400">Andere Datei wählen</p>`;
  }

  fileInput?.addEventListener('change', () => {
    if (fileInput.files?.[0]) showFileName(fileInput.files[0].name);
  });

  dropZone?.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('border-[var(--color-primary)]', 'bg-[#f0f7f6]'); });
  dropZone?.addEventListener('dragleave', () => { dropZone.classList.remove('border-[var(--color-primary)]', 'bg-[#f0f7f6]'); });
  dropZone?.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-[var(--color-primary)]', 'bg-[#f0f7f6]');
    const file = e.dataTransfer?.files?.[0];
    if (!file) return;
    const dt = new DataTransfer();
    dt.items.add(file);
    fileInput.files = dt.files;
    showFileName(file.name);
  });

  // Fortschrittsanzeige via XMLHttpRequest (fetch unterstützt kein Upload-Progress)
  function uploadFile(file: File, path: string): Promise<void> {
    return new Promise((resolve, reject) => {
      const xhr = new XMLHttpRequest();
      const progressWrap = document.getElementById('progress-wrap')!;
      const progressBar  = document.getElementById('progress-bar')!;
      const progressText = document.getElementById('progress-text')!;

      progressWrap.classList.remove('hidden');

      xhr.upload.addEventListener('progress', (e) => {
        if (!e.lengthComputable) return;
        const pct = Math.round((e.loaded / e.total) * 100);
        progressBar.style.width = pct + '%';
        progressText.textContent = pct + '%';
      });

      xhr.addEventListener('load', () => {
        if (xhr.status >= 200 && xhr.status < 300) {
          progressBar.style.width = '100%';
          progressText.textContent = '100%';
          resolve();
        } else {
          reject(new Error(`Storage-Fehler ${xhr.status}: ${xhr.responseText}`));
        }
      });
      xhr.addEventListener('error', () => reject(new Error('Upload fehlgeschlagen')));

      xhr.open('POST', `${SUPABASE_URL}/storage/v1/object/${BUCKET}/${path}`);
      xhr.setRequestHeader('apikey', SUPABASE_KEY);
      xhr.setRequestHeader('Authorization', `Bearer ${getJwt()}`);
      xhr.send(file);
    });
  }

  let cache: any[] = [];

  async function loadDokumente() {
    const tbody = document.getElementById('dok-table-body');
    if (!tbody) return;

    let data: any[];
    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/dokumente?select=*&order=kategorie.asc,created_at.desc`,
        { headers: headers() }
      );
      if (res.status === 401) { window.location.replace('/mitglieder/login'); return; }
      data = await res.json();
    } catch (e: any) {
      tbody.innerHTML = `<tr><td colspan="5" class="px-4 py-6 text-center text-red-500">Fehler: ${e.message}</td></tr>`;
      return;
    }

    cache = Array.isArray(data) ? data : [];

    if (!cache.length) {
      tbody.innerHTML = `<tr><td colspan="5" class="px-4 py-6 text-center text-gray-400">Keine Dokumente vorhanden.</td></tr>`;
      return;
    }

    tbody.innerHTML = cache.map(d => {
      const filename = d.datei_url?.split('/').pop() || '';
      return `
      <tr class="border-t border-gray-100">
        <td class="px-4 py-3 font-medium">${escapeHtml(d.name)}</td>
        <td class="px-4 py-3 text-gray-500">${escapeHtml(d.kategorie || '—')}</td>
        <td class="px-4 py-3 text-gray-500">${escapeHtml(d.beschreibung || '—')}</td>
        <td class="px-4 py-3">
          <a href="${escapeHtml(d.datei_url)}" target="_blank" rel="noopener"
             class="text-[var(--color-primary)] hover:underline text-xs">
            ${escapeHtml(filename)}
          </a>
        </td>
        <td class="px-4 py-3">
          <button onclick="deleteDokument('${d.id}')" class="text-red-500 hover:text-red-700 text-sm font-medium">Löschen</button>
        </td>
      </tr>`;
    }).join('');
  }

  async function deleteDokument(id: string) {
    const d = cache.find(x => x.id === id);
    if (!confirm(`Dokument "${d?.name || id}" wirklich löschen?`)) return;

    // Datei aus Storage löschen
    if (d?.storage_path) {
      await fetch(`${SUPABASE_URL}/storage/v1/object/${BUCKET}/${d.storage_path}`, {
        method: 'DELETE',
        headers: headers(),
      });
    }

    const res = await fetch(`${SUPABASE_URL}/rest/v1/dokumente?id=eq.${id}`, {
      method: 'DELETE',
      headers: headers(),
    });
    if (!res.ok) { showToast('Fehler beim Löschen: ' + res.status, 'error'); return; }
    loadDokumente();
    showToast(`"${d?.name || ''}" wurde gelöscht`);
  }

  (window as any).deleteDokument = deleteDokument;

  loadDokumente();

  document.getElementById('add-dok-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const name         = (document.getElementById('dok-name') as HTMLInputElement).value.trim();
    const kategorie    = (document.getElementById('dok-kategorie') as HTMLInputElement).value.trim() || null;
    const beschreibung = (document.getElementById('dok-beschreibung') as HTMLInputElement).value.trim() || null;
    const file         = (document.getElementById('dok-file') as HTMLInputElement).files?.[0];

    const errEl    = document.getElementById('dok-error')!;
    const okEl     = document.getElementById('dok-success')!;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

    errEl.classList.add('hidden');
    okEl.classList.add('hidden');

    if (!name) { errEl.textContent = 'Name ist erforderlich.'; errEl.classList.remove('hidden'); return; }
    if (!file)  { errEl.textContent = 'Bitte eine Datei auswählen.'; errEl.classList.remove('hidden'); return; }
    if (file.size > 20 * 1024 * 1024) { errEl.textContent = 'Datei ist zu groß (max. 20 MB).'; errEl.classList.remove('hidden'); return; }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Wird hochgeladen…';

    // Eindeutiger Pfad: timestamp_slug_originalname
    const ts = Date.now();
    const storagePath = `${ts}_${slugify(file.name)}`;

    try {
      await uploadFile(file, storagePath);
    } catch (err: any) {
      errEl.textContent = err.message;
      errEl.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Hochladen';
      document.getElementById('progress-wrap')?.classList.add('hidden');
      return;
    }

    const datei_url = `${SUPABASE_URL}/storage/v1/object/public/${BUCKET}/${storagePath}`;

    const res = await fetch(`${SUPABASE_URL}/rest/v1/dokumente`, {
      method: 'POST',
      headers: { ...headers(), Prefer: 'return=minimal' },
      body: JSON.stringify({ name, kategorie, beschreibung, datei_url, storage_path: storagePath }),
    });

    submitBtn.disabled = false;
    submitBtn.textContent = 'Hochladen';
    document.getElementById('progress-wrap')?.classList.add('hidden');
    document.getElementById('progress-bar')!.style.width = '0%';

    if (!res.ok) {
      errEl.textContent = 'Fehler beim Speichern: ' + res.status;
      errEl.classList.remove('hidden');
      return;
    }

    okEl.textContent = `"${name}" wurde hochgeladen!`;
    okEl.classList.remove('hidden');
    (e.target as HTMLFormElement).reset();
    dropLabel.innerHTML = `
      <i class="fa-solid fa-cloud-arrow-up text-3xl text-gray-300"></i>
      <p class="text-sm text-gray-500">Datei hier ablegen oder <span class="text-[var(--color-primary)] font-medium">auswählen</span></p>
      <p class="text-xs text-gray-400">PDF, Word, Excel, ZIP — max. 20 MB</p>`;
    loadDokumente();
    showToast(`"${name}" wurde hochgeladen`);
  });
</script>
