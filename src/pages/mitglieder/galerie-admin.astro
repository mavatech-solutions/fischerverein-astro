---
import ModeratorLayout from "../../layouts/ModeratorLayout.astro";
---

<ModeratorLayout title="Galerie verwalten">
  <div class="container mx-auto px-4 py-24">
    <p class="mb-2 text-3xl font-semibold">Galerie verwalten</p>
    <p class="text-gray-500 mb-10">Bilder hinzufügen und löschen</p>

    <!-- Bild hinzufügen -->
    <div class="bg-white shadow rounded-xl p-6 mb-10">
      <h2 class="h3 mb-6">Bild hinzufügen</h2>

      <div class="bg-amber-50 border border-amber-200 rounded-lg px-4 py-3 text-sm text-amber-800 mb-6">
        <strong>Empfohlene Bild-Dienste:</strong>
        <ul class="mt-1 list-disc list-inside space-y-0.5">
          <li><strong>imgur.com</strong> — kostenlos, kein Account nötig → Bild hochladen → rechtsklick → "Bild-Adresse kopieren"</li>
          <li><strong>cloudinary.com</strong> — kostenloses Konto, professionelles CDN</li>
          <li>Jede direkte Bild-URL die auf <code class="bg-amber-100 px-1 rounded">.jpg</code>, <code class="bg-amber-100 px-1 rounded">.png</code> o.ä. endet</li>
        </ul>
        <p class="mt-1.5 text-amber-700 text-xs">⚠ Google Drive URLs funktionieren nicht zuverlässig für Bild-Einbettung.</p>
      </div>

      <form id="add-bild-form" class="grid grid-cols-12 gap-4">
        <div class="col-span-12 md:col-span-4">
          <label class="block text-sm font-medium text-gray-700 mb-1">Album</label>
          <select
            id="bild-album"
            class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-[var(--color-primary)]"
          >
            <option value="Angelwettbewerbe">Angelwettbewerbe</option>
            <option value="Vereinsleben & Veranstaltungen">Vereinsleben &amp; Veranstaltungen</option>
            <option value="Am Wasser">Am Wasser</option>
            <option value="Größte Fänge">Größte Fänge</option>
          </select>
        </div>

        <div class="col-span-12 md:col-span-8">
          <label class="block text-sm font-medium text-gray-700 mb-1">Bild-URL *</label>
          <input
            id="bild-src"
            type="url"
            placeholder="https://drive.google.com/file/d/.../view  oder  https://imgur.com/..."
            class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-[var(--color-primary)]"
          />
          <p id="bild-src-hint" class="text-xs text-green-600 mt-1 hidden">Google Drive Link wurde automatisch umgewandelt.</p>
        </div>

        <div class="col-span-12 md:col-span-6">
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Vorschau-URL
            <span class="text-gray-400 font-normal">(optional — falls leer, wird Bild-URL verwendet)</span>
          </label>
          <input
            id="bild-thumb"
            type="url"
            placeholder="https://..."
            class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-[var(--color-primary)]"
          />
        </div>

        <div class="col-span-12 md:col-span-6">
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Beschriftung
            <span class="text-gray-400 font-normal">(optional)</span>
          </label>
          <input
            id="bild-caption"
            type="text"
            placeholder="z.B. Sommerfest 2024"
            class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:border-[var(--color-primary)]"
          />
        </div>

        <div class="col-span-12 flex items-center gap-4">
          <button
            type="submit"
            class="bg-[var(--color-primary)] text-white px-6 py-2 rounded-md font-semibold hover:opacity-90 transition"
          >
            Hinzufügen
          </button>
          <p id="add-error" class="text-red-500 text-sm hidden"></p>
          <p id="add-success" class="text-green-600 text-sm hidden"></p>
        </div>
      </form>
    </div>

    <!-- Bilderliste -->
    <div class="bg-white shadow rounded-xl p-6">
      <h2 class="h3 mb-6">Alle Bilder</h2>
      <div id="bilder-list">
        <p class="text-gray-400 text-sm">Lädt...</p>
      </div>
    </div>
  </div>
</ModeratorLayout>

<script>
  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  function showToast(msg: string, type: 'success' | 'error' = 'success') {
    const isError = type === 'error';
    const div = document.createElement('div');
    div.style.cssText = [
      'position:fixed;bottom:24px;right:24px;z-index:9999',
      'padding:13px 20px;border-radius:12px',
      `background:${isError ? '#dc2626' : '#16a34a'};color:#fff`,
      'font-size:14px;font-weight:500;font-family:inherit',
      'display:flex;align-items:center;gap:10px',
      'box-shadow:0 4px 20px rgba(0,0,0,.18)',
      'transform:translateY(10px);opacity:0',
      'transition:opacity .25s ease,transform .25s ease',
      'max-width:360px;line-height:1.4',
    ].join(';');
    div.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0">${
      isError
        ? '<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>'
        : '<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5-4-4 1.41-1.41L10 13.67l6.59-6.59L18 8.5l-8 8z"/>'
    }</svg><span>${msg}</span>`;
    document.body.appendChild(div);
    requestAnimationFrame(() => requestAnimationFrame(() => {
      div.style.opacity = '1';
      div.style.transform = 'translateY(0)';
    }));
    setTimeout(() => {
      div.style.opacity = '0';
      div.style.transform = 'translateY(10px)';
      setTimeout(() => div.remove(), 300);
    }, 4500);
  }

  function getJwt() {
    const key = Object.keys(localStorage).find(k => k.includes('auth-token'));
    const stored = key ? JSON.parse(localStorage.getItem(key) || '{}') : {};
    return stored?.access_token || SUPABASE_KEY;
  }

  function headers() {
    return {
      apikey: SUPABASE_KEY,
      Authorization: `Bearer ${getJwt()}`,
      'Content-Type': 'application/json',
    };
  }

  function escapeHtml(str: string) {
    return String(str)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;');
  }

  function handleUnauthorized(res: Response) {
    if (res.status === 401) {
      window.location.replace('/mitglieder/login');
      return true;
    }
    return false;
  }

  let bilderCache: any[] = [];

  const ALBUM_ORDER = ['Angelwettbewerbe', 'Vereinsleben & Veranstaltungen', 'Am Wasser', 'Größte Fänge'];

  function drivePreviewUrl(url: string): string {
    const id = url?.match(/[?&]id=([a-zA-Z0-9_-]+)/)?.[1]
      ?? url?.match(/\/d\/([a-zA-Z0-9_-]+)/)?.[1];
    if (id && url.includes('drive.google.com')) {
      return `https://lh3.googleusercontent.com/d/${id}`;
    }
    return url;
  }

  async function loadBilder() {
    const container = document.getElementById('bilder-list');
    if (!container) return;

    let data: any[];
    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/galerie_bilder?select=*&order=album.asc,sort_order.asc,created_at.asc`,
        { headers: headers() }
      );
      if (!res.ok) {
        if (handleUnauthorized(res)) return;
        container.innerHTML = `<p class="text-red-500 text-sm">Supabase Fehler ${res.status}: ${await res.text()}</p>`;
        return;
      }
      data = await res.json();
      console.log('[galerie-admin] Geladene Bilder:', data);
    } catch (e: any) {
      container.innerHTML = `<p class="text-red-500 text-sm">Fehler: ${e.message}</p>`;
      return;
    }

    bilderCache = Array.isArray(data) ? data : [];

    if (!bilderCache.length) {
      container.innerHTML = '<p class="text-gray-400 text-sm">Noch keine Bilder vorhanden.</p>';
      return;
    }

    // Gruppieren nach Album
    const grouped: Record<string, any[]> = {};
    for (const b of bilderCache) {
      if (!grouped[b.album]) grouped[b.album] = [];
      grouped[b.album].push(b);
    }

    const order = ALBUM_ORDER.filter(a => grouped[a]);
    const rest = Object.keys(grouped).filter(a => !ALBUM_ORDER.includes(a));

    let html = `<p class="text-xs text-gray-400 mb-4">${bilderCache.length} Bild${bilderCache.length !== 1 ? 'er' : ''} gespeichert</p>`;
    for (const album of [...order, ...rest]) {
      html += `
        <div class="mb-8">
          <h3 class="text-base font-semibold text-gray-700 mb-3">${escapeHtml(album)}</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            ${grouped[album].map(b => {
              const previewSrc = escapeHtml(b.thumb ? b.thumb : drivePreviewUrl(b.src));
              return `
              <div class="border border-gray-100 rounded-lg overflow-hidden">
                <div class="aspect-video bg-gray-100 overflow-hidden">
                  <img
                    src="${previewSrc}"
                    alt="${escapeHtml(b.caption || '')}"
                    class="w-full h-full object-cover"
                    onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
                  />
                  <p class="text-xs text-gray-400 items-center justify-center h-full" style="display:none">Bild nicht ladbar</p>
                </div>
                <div class="p-3">
                  ${b.caption ? `<p class="text-sm font-medium text-gray-700 mb-1">${escapeHtml(b.caption)}</p>` : ''}
                  <p class="text-xs text-gray-400 truncate" title="${escapeHtml(b.src)}">${escapeHtml(b.src)}</p>
                  <button
                    onclick="deleteBild('${b.id}')"
                    class="mt-2 text-xs text-red-500 hover:text-red-700 font-medium"
                  >Löschen</button>
                </div>
              </div>`;
            }).join('')}
          </div>
        </div>
      `;
    }

    container.innerHTML = html;
  }

  async function deleteBild(id: string) {
    const b = bilderCache.find(x => x.id === id);
    const label = b?.caption || b?.src || id;
    if (!confirm(`Bild "${label}" wirklich löschen?`)) return;

    const res = await fetch(`${SUPABASE_URL}/rest/v1/galerie_bilder?id=eq.${id}`, {
      method: 'DELETE',
      headers: headers(),
    });

    if (!res.ok) {
      showToast('Fehler beim Löschen: ' + res.status, 'error');
      return;
    }

    loadBilder();
    showToast('Bild wurde gelöscht');
  }

  (window as any).deleteBild = deleteBild;

  document.getElementById('bild-src')?.addEventListener('input', (e) => {
    const input = e.target as HTMLInputElement;
    const hint = document.getElementById('bild-src-hint');
    const val = input.value.trim();

    const imgurMatch = val.match(/^https?:\/\/imgur\.com\/([a-zA-Z0-9]+)$/);
    if (imgurMatch) {
      input.value = `https://i.imgur.com/${imgurMatch[1]}.jpg`;
      if (hint) { hint.textContent = '✓ Imgur-Link umgewandelt.'; hint.className = 'text-xs text-green-600 mt-1'; }
      return;
    }

    if (hint) {
      if (val.includes('drive.google.com')) {
        hint.textContent = '⚠ Google Drive URLs funktionieren nicht. Bitte Imgur verwenden.';
        hint.className = 'text-xs text-amber-600 mt-1';
      } else {
        hint.textContent = '';
        hint.className = 'text-xs mt-1 hidden';
      }
    }
  });

  loadBilder();

  document.getElementById('add-bild-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const album   = (document.getElementById('bild-album') as HTMLSelectElement).value;
    const src     = (document.getElementById('bild-src') as HTMLInputElement).value.trim();
    const thumb   = (document.getElementById('bild-thumb') as HTMLInputElement).value.trim() || null;
    const caption = (document.getElementById('bild-caption') as HTMLInputElement).value.trim() || null;

    const errEl = document.getElementById('add-error');
    const okEl  = document.getElementById('add-success');
    errEl?.classList.add('hidden');
    okEl?.classList.add('hidden');

    if (!src) {
      errEl!.textContent = 'Bild-URL ist erforderlich.';
      errEl?.classList.remove('hidden');
      return;
    }

    const res = await fetch(`${SUPABASE_URL}/rest/v1/galerie_bilder`, {
      method: 'POST',
      headers: { ...headers(), Prefer: 'return=minimal' },
      body: JSON.stringify({ album, src, thumb, caption }),
    });

    if (!res.ok) {
      if (handleUnauthorized(res)) return;
      errEl!.textContent = 'Fehler beim Hinzufügen: ' + res.status;
      errEl?.classList.remove('hidden');
      return;
    }

    okEl!.textContent = 'Bild wurde hinzugefügt!';
    okEl?.classList.remove('hidden');
    (e.target as HTMLFormElement).reset();
    loadBilder();
    showToast('Bild wurde hinzugefügt');
  });
</script>
