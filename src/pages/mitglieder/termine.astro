---
import ProtectedLayout from "../../layouts/ProtectedLayout.astro";
const currentYear = new Date().getFullYear();
import Badge from "../../components/Badge.astro";
---

<ProtectedLayout title="Termine">
  <section class="bg-[var(--color-secondary)] text-white">
    <div class="h-[120px]"></div>
    <div class="container mx-auto px-4">
      <div class="w-full min-[992px]:max-w-[50%]">
        <h1 class="text-4xl font-bold mb-4">Termine {currentYear}</h1>
        <p class="text-lg mb-6">
          Hier findest du alle wichtigen Termine und Veranstaltungen unseres Vereins
          für das Jahr {currentYear}. Von gemeinsamen Treffen über Angelturniere
          bis hin zu Pflegeaktionen am Wasser – bleib immer auf dem Laufenden und
          sei dabei!
        </p>
        <Badge text="Gemeinschaft" />
        <Badge text="Termine" />
        <Badge text="Tradition" />
      </div>

      <div class="h-[120px]"></div>
    </div>
  </section>
  <div class="bg-gray-50 py-12 px-4">
    <div class="mx-auto w-full max-w-3xl">
      <!-- Laden -->
      <div id="termine-loading" class="text-center py-16">
        <div
          class="inline-block w-8 h-8 border-4 border-[var(--color-primary)] border-t-transparent rounded-full animate-spin"
        >
        </div>
        <p class="mt-3 text-gray-500">Lade Termine...</p>
      </div>

      <!-- Alle exportieren -->
      <div id="export-row" style="display:none" class="items-center justify-between mb-6">
        <p id="export-count" class="text-sm text-gray-400"></p>
        <button onclick="downloadAllIcs()"
          class="inline-flex items-center gap-2 text-sm font-medium text-[var(--color-primary)] border border-[var(--color-primary)] px-4 py-2 rounded-xl hover:bg-[#d1e5e3] transition">
          <i class="fa-solid fa-download text-xs"></i> Alle als ICS exportieren
        </button>
      </div>

      <!-- Liste -->
      <div id="termine-list" class="hidden"></div>

      <!-- Leer -->
      <div id="termine-empty" class="hidden text-center py-16">
        <div class="text-6xl mb-4">📅</div>
        <p class="text-lg text-gray-500">
          Keine Termine für {currentYear} vorhanden.
        </p>
      </div>

      <!-- Fehler -->
      <div id="termine-error" class="hidden text-center py-16">
        <div class="text-6xl mb-4">⚠️</div>
        <p class="text-red-500">
          Fehler beim Laden der Termine. Bitte Seite neu laden.
        </p>
      </div>
    </div>
  </div>
</ProtectedLayout>

<script>
  import { requireAuth } from "../../lib/authGuard.js";
  await requireAuth();

  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  const currentYear = new Date().getFullYear();
  const startDate = `${currentYear}-01-01`;
  const endDate = `${currentYear}-12-31`;

  function showToast(msg: string, type: 'success' | 'error' = 'success') {
    const isError = type === 'error';
    const div = document.createElement('div');
    div.style.cssText = [
      'position:fixed;bottom:24px;right:24px;z-index:9999',
      'padding:13px 20px;border-radius:12px',
      `background:${isError ? '#dc2626' : '#16a34a'};color:#fff`,
      'font-size:14px;font-weight:500;font-family:inherit',
      'display:flex;align-items:center;gap:10px',
      'box-shadow:0 4px 20px rgba(0,0,0,.18)',
      'transform:translateY(10px);opacity:0',
      'transition:opacity .25s ease,transform .25s ease',
      'max-width:360px;line-height:1.4',
    ].join(';');
    div.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0">${
      isError
        ? '<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>'
        : '<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5-4-4 1.41-1.41L10 13.67l6.59-6.59L18 8.5l-8 8z"/>'
    }</svg><span>${msg}</span>`;
    document.body.appendChild(div);
    requestAnimationFrame(() => requestAnimationFrame(() => {
      div.style.opacity = '1';
      div.style.transform = 'translateY(0)';
    }));
    setTimeout(() => {
      div.style.opacity = '0';
      div.style.transform = 'translateY(10px)';
      setTimeout(() => div.remove(), 300);
    }, 4500);
  }

  const storageKey = Object.keys(localStorage).find((k) => k.includes("auth-token"));
  const stored = storageKey ? JSON.parse(localStorage.getItem(storageKey) || "{}") : {};
  const jwt = stored?.access_token;
  const userId = stored?.user?.id;

  const elLoading = document.getElementById("termine-loading");
  const elList    = document.getElementById("termine-list");
  const elEmpty   = document.getElementById("termine-empty");
  const elError   = document.getElementById("termine-error");

  const MONTHS = ["Januar","Februar","März","April","Mai","Juni","Juli","August","September","Oktober","November","Dezember"];

  type TeilnahmeEntry = { ja: string[]; nein: string[]; userStatus: string | null };
  let teilnahmeMap = new Map<string, TeilnahmeEntry>();
  let termineAll: any[] = [];

  function esc(s: string) {
    return String(s).replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;");
  }

  function tagHtml(tags: any[]) {
    if (!tags?.length) return "";
    const colorClass: Record<string, string> = {
      primary: "bg-[#d1e5e3] text-[var(--color-secondary)]",
      dark:    "bg-gray-200 text-gray-800",
      gray:    "bg-gray-100 text-gray-500",
      blue:    "bg-blue-100 text-blue-700",
      orange:  "bg-orange-100 text-orange-700",
      red:     "bg-red-100 text-red-600",
    };
    return `<div class="flex flex-wrap gap-1.5 mb-2">${tags.map(tag =>
      `<span class="px-2 py-0.5 rounded-full text-xs font-medium ${colorClass[tag.color] || colorClass["primary"]}">${esc(tag.text)}</span>`
    ).join("")}</div>`;
  }

  function formatDate(dateStr: string) {
    const d = new Date(dateStr + "T00:00:00");
    return {
      day: d.getDate(),
      monthShort: MONTHS[d.getMonth()].slice(0, 3),
      weekday: d.toLocaleDateString("de-DE", { weekday: "long" }),
    };
  }

  function buildGoogleUrl(t: any): string {
    const dateStr = t.datum.replaceAll("-", "");
    let dates: string;
    if (t.uhrzeit) {
      const [h, m] = t.uhrzeit.split(":").map(Number);
      const start = `${String(h).padStart(2, "0")}${String(m).padStart(2, "0")}00`;
      const endH = (h + 2) % 24;
      const end = `${String(endH).padStart(2, "0")}${String(m).padStart(2, "0")}00`;
      dates = `${dateStr}T${start}/${dateStr}T${end}`;
    } else {
      const next = new Date(t.datum + "T00:00:00");
      next.setDate(next.getDate() + 1);
      dates = `${dateStr}/${next.toISOString().slice(0, 10).replaceAll("-", "")}`;
    }
    const p = new URLSearchParams({ action: "TEMPLATE", text: t.titel, dates });
    if (t.beschreibung) p.set("details", t.beschreibung);
    if (t.ort) p.set("location", t.ort);
    return `https://calendar.google.com/calendar/render?${p}`;
  }

  function buildIcsContent(events: any[]): string {
    const now = new Date().toISOString().replace(/[-:.]/g, "").slice(0, 15) + "Z";
    const lines: string[] = [
      "BEGIN:VCALENDAR", "VERSION:2.0",
      "PRODID:-//Fischerverein//DE", "CALSCALE:GREGORIAN", "METHOD:PUBLISH",
    ];
    for (const t of events) {
      const dateStr = t.datum.replaceAll("-", "");
      lines.push("BEGIN:VEVENT");
      lines.push(`UID:termin-${t.id}@fischerverein.local`);
      lines.push(`DTSTAMP:${now}`);
      lines.push(`SUMMARY:${t.titel}`);
      if (t.beschreibung) lines.push(`DESCRIPTION:${t.beschreibung.replaceAll("\n", "\\n")}`);
      if (t.ort) lines.push(`LOCATION:${t.ort}`);
      if (t.uhrzeit) {
        const [h, m] = t.uhrzeit.split(":").map(Number);
        const start = `${String(h).padStart(2, "0")}${String(m).padStart(2, "0")}00`;
        const endH = (h + 2) % 24;
        const end = `${String(endH).padStart(2, "0")}${String(m).padStart(2, "0")}00`;
        lines.push(`DTSTART;TZID=Europe/Berlin:${dateStr}T${start}`);
        lines.push(`DTEND;TZID=Europe/Berlin:${dateStr}T${end}`);
      } else {
        const next = new Date(t.datum + "T00:00:00");
        next.setDate(next.getDate() + 1);
        lines.push(`DTSTART;VALUE=DATE:${dateStr}`);
        lines.push(`DTEND;VALUE=DATE:${next.toISOString().slice(0, 10).replaceAll("-", "")}`);
      }
      lines.push("END:VEVENT");
    }
    lines.push("END:VCALENDAR");
    return lines.join("\r\n");
  }

  function triggerIcsDownload(content: string, filename: string) {
    const blob = new Blob([content], { type: "text/calendar;charset=utf-8" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url; a.download = filename;
    document.body.appendChild(a); a.click();
    document.body.removeChild(a); URL.revokeObjectURL(url);
  }

  function downloadAllIcs() {
    if (!termineAll.length) return;
    triggerIcsDownload(buildIcsContent(termineAll), `fischerverein-termine-${currentYear}.ics`);
  }

  function downloadSingleIcs(id: string) {
    const t = termineAll.find(x => x.id === id);
    if (!t) return;
    const name = t.titel.toLowerCase().replaceAll(/[^a-z0-9]+/g, "-");
    triggerIcsDownload(buildIcsContent([t]), `${name}.ics`);
    document.getElementById(`cal-dd-${id}`)?.classList.add("hidden");
  }

  function toggleCalDd(id: string) {
    document.querySelectorAll('[id^="cal-dd-"]').forEach(el => {
      if (el.id !== `cal-dd-${id}`) el.classList.add("hidden");
    });
    document.getElementById(`cal-dd-${id}`)?.classList.toggle("hidden");
  }

  function showParticipants(id: string) {
    document.getElementById(`pl-${id}`)?.classList.remove("hidden");
  }
  function hideParticipants(id: string) {
    document.getElementById(`pl-${id}`)?.classList.add("hidden");
  }
  function toggleParticipants(id: string) {
    document.getElementById(`pl-${id}`)?.classList.toggle("hidden");
  }

  async function toggleTeilnahme(terminId: string, status: string) {
    const current = teilnahmeMap.get(terminId)?.userStatus;
    const h = { apikey: SUPABASE_KEY, Authorization: `Bearer ${jwt}` };

    // Bestehenden Eintrag immer zuerst löschen
    if (current) {
      await fetch(`${SUPABASE_URL}/rest/v1/termine_teilnahme?termin_id=eq.${terminId}&user_id=eq.${userId}`, {
        method: "DELETE", headers: h,
      });
    }

    // Neuen Status eintragen — außer wenn derselbe Button nochmal gedrückt wird (toggle off)
    if (current !== status) {
      await fetch(`${SUPABASE_URL}/rest/v1/termine_teilnahme`, {
        method: "POST",
        headers: { ...h, "Content-Type": "application/json" },
        body: JSON.stringify({ termin_id: terminId, user_id: userId, status }),
      });
    }

    if (current !== status) {
      showToast(status === 'ja' ? 'Teilnahme bestätigt' : 'Abgesagt');
    } else {
      showToast('Teilnahme zurückgezogen');
    }
    ladeTermine();
  }

  async function ladeTermine() {
    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/termine?datum=gte.${startDate}&datum=lte.${endDate}&order=datum.asc`,
        { headers: { apikey: SUPABASE_KEY, Authorization: `Bearer ${jwt}` } }
      );
      if (!res.ok) throw new Error("HTTP " + res.status);
      const termine = (await res.json()) as any[];
      termineAll = termine;

      elLoading?.classList.add("hidden");
      if (!termine?.length) { elEmpty?.classList.remove("hidden"); return; }

      const exportRow = document.getElementById("export-row");
      const exportCount = document.getElementById("export-count");
      if (exportRow) exportRow.style.display = "flex";
      if (exportCount) exportCount.textContent = `${termine.length} Termin${termine.length !== 1 ? "e" : ""} ${currentYear}`;

      // Teilnahme + Profile parallel laden
      const ids = termine.map((t: any) => t.id).join(",");
      const [tnRes, profRes] = await Promise.all([
        fetch(`${SUPABASE_URL}/rest/v1/termine_teilnahme?termin_id=in.(${ids})&select=termin_id,status,user_id`,
          { headers: { apikey: SUPABASE_KEY, Authorization: `Bearer ${jwt}` } }),
        fetch(`${SUPABASE_URL}/rest/v1/profiles?select=id,full_name`,
          { headers: { apikey: SUPABASE_KEY, Authorization: `Bearer ${jwt}` } }),
      ]);
      const tnData   = tnRes.ok   ? (await tnRes.json())   as any[] : [];
      const profData = profRes.ok ? (await profRes.json())  as any[] : [];

      const profileMap = new Map<string, string>(profData.map((p: any) => [p.id, p.full_name || "Unbekannt"]));

      teilnahmeMap = new Map();
      for (const t of termine) teilnahmeMap.set(t.id, { ja: [], nein: [], userStatus: null });
      for (const tn of tnData) {
        const entry = teilnahmeMap.get(tn.termin_id);
        if (!entry) continue;
        const name = profileMap.get(tn.user_id) || "Unbekannt";
        if (tn.status === "ja")   entry.ja.push(name);
        if (tn.status === "nein") entry.nein.push(name);
        if (tn.user_id === userId) entry.userStatus = tn.status;
      }

      // Nach Monat gruppieren
      const grouped = new Map<number, any[]>();
      for (const t of termine) {
        const m = new Date(t.datum + "T00:00:00").getMonth();
        if (!grouped.has(m)) grouped.set(m, []);
        grouped.get(m)!.push(t);
      }

      let html = "";
      for (const [monthIdx, events] of grouped) {
        html += `<div class="mb-10">
          <div class="flex items-center gap-3 mb-4">
            <span class="w-1 h-7 bg-[var(--color-primary)] rounded-full"></span>
            <h2 class="text-xl font-semibold text-[var(--color-secondary)] m-0">${MONTHS[monthIdx]}</h2>
          </div>
          <div class="space-y-3">`;

        for (const t of events) {
          const d  = formatDate(t.datum);
          const tt = teilnahmeMap.get(t.id) || { ja: [], nein: [], userStatus: null };
          const uhrzeit = t.uhrzeit ? t.uhrzeit.slice(0, 5) + " Uhr" : "";

          const jaList   = tt.ja.length
            ? `<p class="text-xs font-semibold text-gray-500 mb-1.5">Dabei (${tt.ja.length})</p>
               <ul class="space-y-1 mb-2">${tt.ja.map(n =>
                 `<li class="text-xs text-gray-700 flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-primary)] flex-shrink-0 inline-block"></span>${esc(n)}
                  </li>`).join("")}</ul>`
            : "";
          const neinList = tt.nein.length
            ? `<p class="text-xs font-semibold text-gray-500 mb-1.5">Abgesagt (${tt.nein.length})</p>
               <ul class="space-y-1">${tt.nein.map(n =>
                 `<li class="text-xs text-gray-500 flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-red-300 flex-shrink-0 inline-block"></span>${esc(n)}
                  </li>`).join("")}</ul>`
            : "";
          const participantList = jaList || neinList
            ? jaList + neinList
            : `<p class="text-xs text-gray-400">Noch keine Antworten</p>`;

          const btnJa   = tt.userStatus === "ja"
            ? `bg-[var(--color-primary)] text-white`
            : `border border-[var(--color-primary)] text-[var(--color-primary)] bg-white`;
          const btnNein = tt.userStatus === "nein"
            ? `bg-red-100 text-red-600 border border-red-200`
            : `border border-gray-300 text-gray-500 bg-white`;

          html += `
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 flex gap-4 hover:shadow-md transition-shadow">
              <div class="flex-shrink-0 w-14 text-center pt-1">
                <div class="text-2xl font-bold leading-none text-[var(--color-primary)]">${d.day}</div>
                <div class="text-sm text-gray-400 uppercase mt-1">${d.monthShort}</div>
                <div class="text-sm text-gray-400 mt-1">${d.weekday.slice(0, 2)}.</div>
              </div>
              <div class="w-px bg-gray-100 self-stretch flex-shrink-0"></div>
              <div class="flex-1 min-w-0">
                <h3 class="font-semibold text-[var(--color-dark)] mb-1 text-base leading-tight m-0 hyphens-auto">${esc(t.titel)}</h3>
                ${tagHtml(t.tags || [])}
                ${t.beschreibung ? `<p class="text-sm text-gray-600 mb-2 leading-relaxed">${esc(t.beschreibung)}</p>` : ""}
                <div class="flex flex-wrap gap-4 text-sm text-gray-400">
                  ${uhrzeit ? `<span class="flex items-center gap-1"><i class="fa-regular fa-clock"></i> ${uhrzeit}</span>` : ""}
                  ${t.ort ? `<span class="flex items-center gap-1"><i class="fa-solid fa-location-dot"></i> ${esc(t.ort)}</span>` : ""}
                </div>
                <div class="flex flex-wrap items-center justify-between gap-2 mt-3 pt-3 border-t border-gray-100">
                  <div class="flex items-center gap-3">
                    <div class="relative">
                      <button
                        onmouseenter="showParticipants('${t.id}')"
                        onmouseleave="hideParticipants('${t.id}')"
                        onclick="event.stopPropagation(); toggleParticipants('${t.id}')"
                        class="flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-700 transition cursor-pointer">
                        <i class="fa-solid fa-users"></i>
                        <span>${tt.ja.length} Teilnehmer</span>
                      </button>
                      <div id="pl-${t.id}" class="hidden absolute bottom-full left-0 mb-2 bg-white shadow-lg border border-gray-100 rounded-xl p-3 z-20 w-52">
                        ${participantList}
                      </div>
                    </div>
                    <div class="relative">
                      <button onclick="event.stopPropagation(); toggleCalDd('${t.id}')"
                        class="flex items-center gap-1 text-sm text-gray-400 hover:text-[var(--color-primary)] transition cursor-pointer">
                        <i class="fa-regular fa-calendar-plus"></i>
                        Kalender
                      </button>
                      <div id="cal-dd-${t.id}" class="hidden absolute bottom-full left-0 mb-2 bg-white shadow-lg border border-gray-100 rounded-xl py-1.5 z-20 w-52">
                        <a href="${buildGoogleUrl(t)}" target="_blank" rel="noopener"
                          class="flex items-center gap-2.5 px-4 py-2 text-xs text-gray-700 hover:bg-gray-50 transition">
                          <i class="fa-brands fa-google text-[#4285F4]"></i> Google Kalender
                        </a>
                        <button onclick="downloadSingleIcs('${t.id}')"
                          class="w-full flex items-center gap-2.5 px-4 py-2 text-xs text-gray-700 hover:bg-gray-50 transition text-left">
                          <i class="fa-solid fa-download text-gray-400"></i> ICS-Datei (Outlook, Apple…)
                        </button>
                      </div>
                    </div>
                  </div>
                  <div class="flex gap-2">
                    <button onclick="toggleTeilnahme('${t.id}', 'ja')"
                      class="${btnJa} px-3 py-1.5 rounded-lg text-sm font-medium transition hover:opacity-80">
                      ${tt.userStatus === "ja" ? "✓ Ich bin dabei" : "Teilnehmen"}
                    </button>
                    <button onclick="toggleTeilnahme('${t.id}', 'nein')"
                      class="${btnNein} px-3 py-1.5 rounded-lg text-sm font-medium transition hover:opacity-80">
                      ${tt.userStatus === "nein" ? "✗ Abgemeldet" : "Absagen"}
                    </button>
                  </div>
                </div>
              </div>
            </div>`;
        }
        html += `</div></div>`;
      }

      elList!.innerHTML = html;
      elList?.classList.remove("hidden");
    } catch (e) {
      elLoading?.classList.add("hidden");
      elError?.classList.remove("hidden");
    }
  }

  // Alle offenen Tooltips/Dropdowns schließen wenn außerhalb geklickt wird
  document.addEventListener("click", () => {
    document.querySelectorAll('[id^="pl-"], [id^="cal-dd-"]').forEach(el => el.classList.add("hidden"));
  });

  (window as any).showParticipants   = showParticipants;
  (window as any).hideParticipants   = hideParticipants;
  (window as any).toggleParticipants = toggleParticipants;
  (window as any).toggleTeilnahme    = toggleTeilnahme;
  (window as any).toggleCalDd        = toggleCalDd;
  (window as any).downloadSingleIcs  = downloadSingleIcs;
  (window as any).downloadAllIcs     = downloadAllIcs;

  ladeTermine();
</script>
